{%- if settings.announcement_text != blank -%}
  <div class="pr-announce">
    <div class="pr-announce__mobile mh-announce">
      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m6 0a2 2 0 104 0" />
      </svg>
      <span>{{ settings.announcement_text }}</span>
    </div>
    <div class="pr-announce__desktop dh-announce">
      <div class="dh-announce__inner">
        <div class="dh-announce__left">
          <span><span class="material-symbols-outlined">local_shipping</span> {{ settings.announcement_text }}</span>
          <span><span class="material-symbols-outlined">inventory_2</span> Made in Small Batches</span>
          <span><span class="material-symbols-outlined">eco</span> No Preservatives</span>
          <span><span class="material-symbols-outlined">home</span> 100% Homemade</span>
        </div>
        <div class="dh-announce__right">
          {%- if settings.phone_tel != blank -%}
            <a href="tel:{{ settings.phone_tel }}">{{ settings.phone_number }}</a>
          {%- endif -%}
          {%- if settings.social_instagram != blank -%}
            <a href="{{ settings.social_instagram }}" aria-label="Instagram" class="dh-announce__social">IG</a>
          {%- endif -%}
          {%- if settings.social_facebook != blank -%}
            <a href="{{ settings.social_facebook }}" aria-label="Facebook" class="dh-announce__social">FB</a>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [],
  "enabled_on": { "groups": ["header"] }
}
{% endschema %}
