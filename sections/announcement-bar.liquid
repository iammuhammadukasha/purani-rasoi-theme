{%- liquid
  assign phone_display = settings.phone_number | default: '+91 98765 43210'
  assign phone_tel = settings.phone_tel | default: '+919876543210'
  assign announce = settings.announcement_text | default: 'Free Shipping on orders above ₹499'
-%}

<div class="pr-announce">
  <div class="pr-announce__mobile mh-announce">
    <span class="material-symbols-outlined" aria-hidden="true">local_shipping</span>
    <span>{{ announce }}</span>
  </div>

  <div class="pr-announce__desktop dh-announce">
    <div class="dh-announce__inner">
      <div class="dh-announce__left">
        <span class="dh-announce__item">
          <span class="material-symbols-outlined" aria-hidden="true">local_shipping</span>
          {{ announce }}
        </span>
        <span class="dh-announce__dot" aria-hidden="true">•</span>
        <span class="dh-announce__item">
          <span class="material-symbols-outlined" aria-hidden="true">shopping_bag</span>
          Made in Small Batches
        </span>
        <span class="dh-announce__dot" aria-hidden="true">•</span>
        <span class="dh-announce__item">
          <span class="material-symbols-outlined" aria-hidden="true">eco</span>
          No Preservatives
        </span>
        <span class="dh-announce__dot" aria-hidden="true">•</span>
        <span class="dh-announce__item">
          <span class="material-symbols-outlined" aria-hidden="true">skillet</span>
          100% Homemade
        </span>
      </div>
      <div class="dh-announce__right">
        <a class="dh-announce__phone" href="tel:{{ phone_tel }}">
          <span class="material-symbols-outlined" aria-hidden="true">call</span>
          {{ phone_display }}
        </a>
        {%- if settings.social_instagram != blank -%}
          <a href="{{ settings.social_instagram }}" class="dh-announce__social" aria-label="Instagram" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" width="12" height="12" aria-hidden="true" fill="currentColor"><path d="M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 0 1-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2m-.2 2A3.6 3.6 0 0 0 4 7.6v8.8C4 18.39 5.61 20 7.6 20h8.8a3.6 3.6 0 0 0 3.6-3.6V7.6C20 5.61 18.39 4 16.4 4H7.6m9.65 1.5a1.25 1.25 0 0 1 1.25 1.25A1.25 1.25 0 0 1 17.25 8 1.25 1.25 0 0 1 16 6.75a1.25 1.25 0 0 1 1.25-1.25M12 7a5 5 0 0 1 5 5 5 5 0 0 1-5 5 5 5 0 0 1-5-5 5 5 0 0 1 5-5m0 2a3 3 0 0 0-3 3 3 3 0 0 0 3 3 3 3 0 0 0 3-3 3 3 0 0 0-3-3z"/></svg>
          </a>
        {%- else -%}
          <a href="#" class="dh-announce__social" aria-label="Instagram">
            <svg viewBox="0 0 24 24" width="12" height="12" aria-hidden="true" fill="currentColor"><path d="M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 0 1-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2m-.2 2A3.6 3.6 0 0 0 4 7.6v8.8C4 18.39 5.61 20 7.6 20h8.8a3.6 3.6 0 0 0 3.6-3.6V7.6C20 5.61 18.39 4 16.4 4H7.6m9.65 1.5a1.25 1.25 0 0 1 1.25 1.25A1.25 1.25 0 0 1 17.25 8 1.25 1.25 0 0 1 16 6.75a1.25 1.25 0 0 1 1.25-1.25M12 7a5 5 0 0 1 5 5 5 5 0 0 1-5 5 5 5 0 0 1-5-5 5 5 0 0 1 5-5m0 2a3 3 0 0 0-3 3 3 3 0 0 0 3 3 3 3 0 0 0 3-3 3 3 0 0 0-3-3z"/></svg>
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Announcement bar",
  "settings": [],
  "enabled_on": { "groups": ["header"] }
}
{% endschema %}
