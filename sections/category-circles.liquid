<section id="categories" class="pr-cats" data-pr-cats aria-labelledby="CatsHeading-{{ section.id }}">
  <div class="pr-cats__head">
    <h2 id="CatsHeading-{{ section.id }}" class="pr-cats__heading">
      <span class="pr-cats__flourish" aria-hidden="true">
        <img src="{{ 'cats-flourish-leaf.png' | asset_url }}" alt="" width="84" height="36" loading="lazy">
      </span>
      <span class="pr-cats__heading-text">{{ section.settings.heading | default: 'Shop By Category' }}</span>
      <span class="pr-cats__flourish pr-cats__flourish--flip" aria-hidden="true">
        <img src="{{ 'cats-flourish-leaf.png' | asset_url }}" alt="" width="84" height="36" loading="lazy">
      </span>
    </h2>
    <div class="pr-cats__rule" aria-hidden="true"></div>
  </div>

  <div class="pr-cats__wrap">
    <button type="button" class="pr-cats__arrow pr-cats__arrow--prev" data-cats-prev aria-label="Previous categories">
      <span class="material-symbols-outlined" aria-hidden="true">chevron_left</span>
    </button>

    <div class="pr-cats__viewport">
      <div class="pr-cats__rail" data-cats-rail>
        {%- for block in section.blocks -%}
          {%- liquid
            assign href = block.settings.link | default: routes.all_products_collection_url
            if block.settings.image != blank
              assign img = block.settings.image | image_url: width: 400
            else
              assign fallback = block.settings.fallback_asset | default: 'aam.png'
              assign img = fallback | asset_url
            endif
          -%}
          <a href="{{ href }}" class="pr-cats__item" {{ block.shopify_attributes }}>
            <span class="pr-cats__ring">
              <img src="{{ img }}" alt="{{ block.settings.title | escape }}" loading="lazy" width="200" height="200">
            </span>
            <span class="pr-cats__label">{{ block.settings.title }}</span>
          </a>
        {%- endfor -%}
      </div>
    </div>

    <button type="button" class="pr-cats__arrow pr-cats__arrow--next" data-cats-next aria-label="Next categories">
      <span class="material-symbols-outlined" aria-hidden="true">chevron_right</span>
    </button>
  </div>
</section>

{% schema %}
{
  "name": "Category circles",
  "tag": "section",
  "class": "pr-cats-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop By Category" },
    { "type": "text", "id": "view_all_label", "label": "View all label (unused)", "default": "View All Categories" },
    { "type": "url", "id": "view_all_link", "label": "View all link" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Aam Ka Achar" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "fallback_asset", "label": "Fallback asset filename", "default": "aam.png", "info": "Used if no image selected (file in theme assets)" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category circles",
      "blocks": [
        { "type": "category", "settings": { "title": "Aam Ka Achar", "fallback_asset": "aam.png" } },
        { "type": "category", "settings": { "title": "Mixed Achar", "fallback_asset": "mixed.png" } },
        { "type": "category", "settings": { "title": "Lehsun Ka Achar", "fallback_asset": "lehsun.png" } },
        { "type": "category", "settings": { "title": "Kathal Ka Achar", "fallback_asset": "aam-featured.png" } },
        { "type": "category", "settings": { "title": "Mirch Achar", "fallback_asset": "mirch.png" } },
        { "type": "category", "settings": { "title": "Nimbu Ka Achar", "fallback_asset": "nimbu.png" } }
      ]
    }
  ]
}
{% endschema %}
