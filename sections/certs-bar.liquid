{%- if section.settings.show_certs -%}
  <section class="pr-trust-marks" aria-labelledby="TrustMarks-{{ section.id }}">
    <div class="pr-trust-marks__inner">
      {%- if section.settings.heading != blank -%}
        <h2 id="TrustMarks-{{ section.id }}" class="pr-trust-marks__heading">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      <div class="pr-trust-marks__row">
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            <div class="pr-trust-marks__pill" {{ block.shopify_attributes }}>
              {%- if block.settings.logo != blank -%}
                <span class="pr-trust-marks__logo">
                  <img
                    src="{{ block.settings.logo | image_url: width: 120 }}"
                    alt=""
                    width="40"
                    height="40"
                    loading="lazy"
                  >
                </span>
              {%- elsif block.settings.label == 'FSSAI' -%}
                <span class="pr-trust-marks__logo">
                  <img
                    src="{{ 'cert-fssai.png' | asset_url }}"
                    alt=""
                    width="40"
                    height="40"
                    loading="lazy"
                  >
                </span>
              {%- else -%}
                <span class="pr-trust-marks__logo pr-trust-marks__logo--initial" aria-hidden="true">
                  {{ block.settings.label | slice: 0, 1 }}
                </span>
              {%- endif -%}
              <span class="pr-trust-marks__label">{{ block.settings.label }}</span>
            </div>
          {%- endfor -%}
        {%- else -%}
          <div class="pr-trust-marks__pill">
            <span class="pr-trust-marks__logo pr-trust-marks__logo--initial" aria-hidden="true">I</span>
            <span class="pr-trust-marks__label">ISO</span>
          </div>
          <div class="pr-trust-marks__pill">
            <span class="pr-trust-marks__logo">
              <img src="{{ 'cert-fssai.png' | asset_url }}" alt="" width="40" height="40" loading="lazy">
            </span>
            <span class="pr-trust-marks__label">FSSAI</span>
          </div>
          <div class="pr-trust-marks__pill">
            <span class="pr-trust-marks__logo pr-trust-marks__logo--initial" aria-hidden="true">F</span>
            <span class="pr-trust-marks__label">FDA</span>
          </div>
          <div class="pr-trust-marks__pill">
            <span class="pr-trust-marks__logo pr-trust-marks__logo--initial" aria-hidden="true">A</span>
            <span class="pr-trust-marks__label">APEDA</span>
          </div>
        {%- endif -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Certifications & Trust",
  "tag": "section",
  "class": "pr-trust-marks-section",
  "settings": [
    { "type": "checkbox", "id": "show_certs", "label": "Show section", "default": true },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Certifications & Trust Marks"
    }
  ],
  "blocks": [
    {
      "type": "mark",
      "name": "Trust mark",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "ISO" },
        { "type": "image_picker", "id": "logo", "label": "Logo" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Certifications & Trust",
      "blocks": [
        { "type": "mark", "settings": { "label": "ISO" } },
        { "type": "mark", "settings": { "label": "FSSAI" } },
        { "type": "mark", "settings": { "label": "FDA" } },
        { "type": "mark", "settings": { "label": "APEDA" } }
      ]
    }
  ]
}
{% endschema %}
