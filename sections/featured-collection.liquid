{%- liquid
  assign collection = section.settings.collection
  if collection == blank and section.settings.collection != blank
    assign collection = collections[section.settings.collection]
  endif
  if collection == blank
    assign collection = collections.all
  endif
  assign products_to_show = section.settings.products_to_show | default: 5
  assign collection_url = collection.url | default: routes.all_products_collection_url
-%}

<section id="bestsellers" class="pr-bestsellers">
  <div class="mh-section mh-section--soft home-mobile">
    <div class="mh-section__head">
      <h2 class="mh-heading">{{ section.settings.heading }}</h2>
      <a href="{{ collection_url }}" class="mh-link-maroon">{{ section.settings.view_all }}</a>
    </div>
    <div class="mh-rail hide-scrollbar">
      {%- if collection != blank -%}
        {%- for product in collection.products limit: products_to_show -%}
          {% render 'product-card', product: product, show_rating: true %}
        {%- else -%}
          <p class="pr-bestsellers__empty">No products in this collection yet.</p>
        {%- endfor -%}
      {%- else -%}
        <p class="pr-bestsellers__empty">Select a collection in the theme editor.</p>
      {%- endif -%}
    </div>
  </div>

  <div class="dh-section dh-section--soft home-desktop">
    <div class="dh-section__head">
      <h2 class="dh-heading">{{ section.settings.heading }}</h2>
      <a href="{{ collection_url }}" class="dh-view-all">{{ section.settings.view_all_desktop }} <span aria-hidden="true">→</span></a>
    </div>
    <div class="dh-products">
      {%- if collection != blank -%}
        {%- for product in collection.products limit: products_to_show -%}
          {% render 'product-card', product: product, show_rating: true %}
        {%- else -%}
          <p class="pr-bestsellers__empty">No products in this collection yet. Add products to the collection in Shopify Admin.</p>
        {%- endfor -%}
      {%- else -%}
        <p class="pr-bestsellers__empty">Select a collection in the theme editor to show products.</p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Best Sellers" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "min": 2, "max": 12, "step": 1, "label": "Products to show", "default": 5 },
    { "type": "text", "id": "view_all", "label": "View all (mobile)", "default": "View All >" },
    { "type": "text", "id": "view_all_desktop", "label": "View all (desktop)", "default": "View All Products" }
  ],
  "presets": [{ "name": "Featured collection" }]
}
{% endschema %}
