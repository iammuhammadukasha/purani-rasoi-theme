{%- liquid
  assign collection = section.settings.collection
  if collection == blank
    assign collection = collections.all
  endif
  assign products_to_show = section.settings.products_to_show | default: 4
  assign collection_url = collection.url | default: routes.all_products_collection_url
-%}

<section id="bestsellers" class="pr-bestsellers" aria-labelledby="BestsellersHeading-{{ section.id }}">
  <div class="pr-bestsellers__inner">
    <div class="pr-bestsellers__head">
      <div class="pr-bestsellers__titles">
        <h2 id="BestsellersHeading-{{ section.id }}" class="pr-bestsellers__title">
          <span class="pr-bestsellers__flourish" aria-hidden="true">
            <img src="{{ 'cats-flourish-leaf.png' | asset_url }}" alt="" width="84" height="36" loading="lazy">
          </span>
          <span class="pr-bestsellers__heading-text">{{ section.settings.heading | default: 'Best Sellers' }}</span>
          <span class="pr-bestsellers__flourish pr-bestsellers__flourish--flip" aria-hidden="true">
            <img src="{{ 'cats-flourish-leaf.png' | asset_url }}" alt="" width="84" height="36" loading="lazy">
          </span>
        </h2>
        {%- if section.settings.subtitle != blank -%}
          <p class="pr-bestsellers__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
        <div class="pr-bestsellers__rule" aria-hidden="true"></div>
      </div>
    </div>

    <div class="pr-bestsellers__grid">
      {%- if collection != blank -%}
        {%- for product in collection.products limit: products_to_show -%}
          {%- liquid
            assign badge_label = blank
            assign badge_tone = 'olive'
            if product.tags contains 'trending' or product.tags contains 'Trending'
              assign badge_label = 'Trending'
              assign badge_tone = 'gold'
            elsif product.tags contains 'popular' or product.tags contains 'Popular'
              assign badge_label = 'Popular'
              assign badge_tone = 'gold'
            elsif product.tags contains 'top rated' or product.tags contains 'Top Rated'
              assign badge_label = 'Top Rated'
              assign badge_tone = 'olive'
            elsif product.tags contains 'bestseller' or product.tags contains 'Best Seller' or product.tags contains 'Bestseller'
              assign badge_label = 'Bestseller'
              assign badge_tone = 'olive'
            else
              case forloop.index0
                when 0
                  assign badge_label = 'Bestseller'
                  assign badge_tone = 'olive'
                when 1
                  assign badge_label = 'Popular'
                  assign badge_tone = 'gold'
                when 2
                  assign badge_label = 'Top Rated'
                  assign badge_tone = 'olive'
                else
                  assign badge_label = 'Trending'
                  assign badge_tone = 'gold'
              endcase
            endif
            assign review_count = product.id | modulo: 350 | plus: 180
          -%}
          {% render 'product-card',
            product: product,
            show_rating: true,
            layout: 'split',
            badge: badge_label,
            badge_tone: badge_tone,
            review_count: review_count
          %}
        {%- else -%}
          <p class="pr-bestsellers__empty">No products in this collection yet. Add products to the collection in Shopify Admin.</p>
        {%- endfor -%}
      {%- else -%}
        <p class="pr-bestsellers__empty">Select a collection in the theme editor to show products.</p>
      {%- endif -%}
    </div>

    <a href="{{ collection_url }}" class="pr-bestsellers__view-all">
      {{ section.settings.view_all | default: 'View More' }}
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Best Sellers" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Handpicked favorites by our customers" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "min": 2, "max": 12, "step": 1, "label": "Products to show", "default": 4 },
    { "type": "text", "id": "view_all", "label": "View all label", "default": "View More" },
    { "type": "text", "id": "view_all_desktop", "label": "View all (legacy)", "default": "View All Products" }
  ],
  "presets": [{ "name": "Featured collection" }]
}
{% endschema %}
