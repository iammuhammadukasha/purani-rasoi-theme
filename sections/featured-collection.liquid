{%- liquid
  assign collection = collections[section.settings.collection]
  assign products_to_show = section.settings.products_to_show | default: 5
-%}

<section id="bestsellers" class="pr-bestsellers">
  <div class="mh-section mh-section--soft home-mobile">
    <div class="mh-section__head">
      <h2 class="mh-heading">— {{ section.settings.heading }} —</h2>
      <a href="{{ collection.url | default: routes.all_products_collection_url }}" class="mh-link-maroon">{{ section.settings.view_all }}</a>
    </div>
    <div class="mh-rail hide-scrollbar">
      {%- if collection != blank and collection.products_count > 0 -%}
        {%- for product in collection.products limit: products_to_show -%}
          {% render 'product-card', product: product, show_rating: true %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..3) -%}
          <article class="bs-card">
            <div class="bs-card__media">{{ 'product-1' | placeholder_svg_tag }}</div>
            <div class="bs-card__body">
              <h3 class="bs-card__title">Sample Achar {{ i }}</h3>
              <p class="bs-card__size">500g</p>
              <div class="bs-card__price"><strong>₹349</strong></div>
            </div>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>

  <div class="dh-section dh-section--soft home-desktop">
    <div class="dh-section__head">
      <h2 class="dh-heading"><span class="dh-flourish"></span> {{ section.settings.heading }} <span class="dh-flourish"></span></h2>
      <a href="{{ collection.url | default: routes.all_products_collection_url }}" class="dh-view-all">{{ section.settings.view_all_desktop }} <span aria-hidden="true">→</span></a>
    </div>
    <div class="dh-products">
      {%- if collection != blank and collection.products_count > 0 -%}
        {%- for product in collection.products limit: products_to_show -%}
          {% render 'product-card', product: product, show_rating: true %}
        {%- endfor -%}
      {%- else -%}
        <p style="text-align:center;padding:2rem;grid-column:1/-1">Select a collection in the theme editor to show products.</p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Best Sellers" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "min": 2, "max": 12, "step": 1, "label": "Products to show", "default": 5 },
    { "type": "text", "id": "view_all", "label": "View all (mobile)", "default": "View All >" },
    { "type": "text", "id": "view_all_desktop", "label": "View all (desktop)", "default": "View All Products" }
  ],
  "presets": [{ "name": "Featured collection" }]
}
{% endschema %}
