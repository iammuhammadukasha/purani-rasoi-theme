{%- liquid
  if settings.logo != blank
    assign logo_src = settings.logo | image_url: width: 96
  else
    assign logo_src = 'logo-purani-rasoi.png' | asset_url
  endif
  assign brand1 = settings.brand_name_line1 | default: 'Purani'
  assign brand2 = settings.brand_name_line2 | default: 'Rasoi'

  if section.settings.link_home != blank
    assign home_url = section.settings.link_home
  else
    assign home_url = routes.root_url
  endif
  if section.settings.link_shop != blank
    assign shop_url = section.settings.link_shop
  else
    assign shop_url = routes.all_products_collection_url
  endif
  if section.settings.link_story != blank
    assign story_url = section.settings.link_story
  else
    assign story_url = routes.root_url | append: '#story'
  endif
  if section.settings.link_blog != blank
    assign blog_url = section.settings.link_blog
  else
    assign blog_url = routes.root_url | append: '#blog'
  endif
  if section.settings.link_wholesale != blank
    assign wholesale_url = section.settings.link_wholesale
  else
    assign wholesale_url = routes.all_products_collection_url
  endif
  if section.settings.link_contact != blank
    assign contact_url = section.settings.link_contact
  else
    assign contact_url = routes.root_url | append: '#contact'
  endif
-%}

<header class="dh-header site-header">
  <div class="dh-header__inner">
    <button type="button" id="menu-open" class="site-header__menu-btn" aria-label="{{ 'general.accessibility.open_menu' | t }}">
      <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <a href="{{ routes.root_url }}" class="dh-logo" aria-label="{{ shop.name }} home">
      <img src="{{ logo_src }}" alt="{{ shop.name | escape }}" width="56" height="56">
    </a>

    <nav class="site-header__nav" aria-label="Primary">
      <ul class="dh-nav">
        <li>
          <a href="{{ home_url }}" {% if request.page_type == 'index' %}class="is-active"{% endif %}>Home</a>
        </li>
        <li class="relative">
          <button type="button" id="shop-toggle" class="dh-nav__btn" aria-expanded="false" aria-controls="shop-menu">
            Shop
            <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div id="shop-menu" class="shop-menu" hidden>
            <a href="{{ shop_url }}">All Products</a>
            <a href="{{ shop_url }}">Best Sellers</a>
            {%- if section.settings.shop_menu != blank -%}
              {%- for child in linklists[section.settings.shop_menu].links -%}
                <a href="{{ child.url }}">{{ child.title }}</a>
              {%- endfor -%}
            {%- endif -%}
          </div>
        </li>
        <li><a href="{{ story_url }}">Our Story</a></li>
        <li><a href="{{ blog_url }}">Recipes &amp; Blog</a></li>
        <li><a href="{{ wholesale_url }}">Wholesale</a></li>
        <li><a href="{{ contact_url }}">Contact</a></li>
      </ul>
    </nav>

    <div class="dh-tools">
      <button type="button" class="dh-tools__search" data-ajax-search-open aria-label="{{ 'general.search' | t }}" aria-expanded="false" aria-controls="ajax-search">
        <span class="material-symbols-outlined">search</span>
      </button>
      <a
        href="{% if shop.customer_accounts_enabled %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}"
        class="dh-tools__account"
        aria-label="{{ 'general.account' | t }}"
      >
        <span class="material-symbols-outlined">person</span>
      </a>
      <a href="{{ routes.cart_url }}" class="dh-tools__cart" aria-label="{{ 'general.cart' | t }}">
        <span class="material-symbols-outlined">shopping_cart</span>
        <span class="cart-count cart-badge">{{ cart.item_count }}</span>
      </a>
    </div>
  </div>
</header>

<div id="ajax-search" class="ajax-search" hidden>
  <div class="ajax-search__backdrop" data-ajax-search-close tabindex="-1"></div>
  <div class="ajax-search__panel" role="dialog" aria-modal="true" aria-labelledby="ajax-search-title">
    <div class="ajax-search__head">
      <h2 id="ajax-search-title" class="sr-only">{{ 'general.search' | t }}</h2>
      <form class="ajax-search__form" role="search" action="{{ routes.search_url }}" method="get" data-ajax-search-form>
        <span class="material-symbols-outlined ajax-search__icon" aria-hidden="true">search</span>
        <label class="sr-only" for="AjaxSearchInput">{{ 'general.search' | t }}</label>
        <input
          id="AjaxSearchInput"
          class="ajax-search__input"
          type="search"
          name="q"
          placeholder="Search for pickles, achar…"
          autocomplete="off"
          data-ajax-search-input
        >
        <input type="hidden" name="type" value="product">
        <button type="button" class="ajax-search__close" data-ajax-search-close aria-label="{{ 'general.accessibility.close' | t }}">✕</button>
      </form>
    </div>
    <p class="ajax-search__meta" data-ajax-search-meta>Type to search products</p>
    <div class="ajax-search__results shop-grid" data-ajax-search-results></div>
  </div>
</div>

<nav id="mobile-nav" class="mobile-nav" aria-label="Mobile">
  <button type="button" id="menu-close" class="mobile-nav__close" aria-label="{{ 'general.accessibility.close' | t }}">✕</button>
  <div class="mobile-nav__brand">
    <img src="{{ logo_src }}" alt="" width="48" height="48">
  </div>
  <a href="{{ home_url }}"><span class="material-symbols-outlined" aria-hidden="true">home</span><span>Home</span></a>
  <a href="{{ shop_url }}"><span class="material-symbols-outlined" aria-hidden="true">storefront</span><span>Shop</span></a>
  <a href="{{ story_url }}"><span class="material-symbols-outlined" aria-hidden="true">menu_book</span><span>Our Story</span></a>
  <a href="{{ blog_url }}"><span class="material-symbols-outlined" aria-hidden="true">article</span><span>Recipes &amp; Blog</span></a>
  <a href="{{ wholesale_url }}"><span class="material-symbols-outlined" aria-hidden="true">inventory_2</span><span>Wholesale</span></a>
  <a href="{{ contact_url }}"><span class="material-symbols-outlined" aria-hidden="true">call</span><span>Contact</span></a>
</nav>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "url", "id": "link_home", "label": "Home link" },
    { "type": "url", "id": "link_shop", "label": "Shop link" },
    { "type": "link_list", "id": "shop_menu", "label": "Shop dropdown menu (optional)" },
    { "type": "url", "id": "link_story", "label": "Our Story link" },
    { "type": "url", "id": "link_blog", "label": "Recipes & Blog link" },
    { "type": "url", "id": "link_wholesale", "label": "Wholesale link" },
    { "type": "url", "id": "link_contact", "label": "Contact link" }
  ],
  "enabled_on": { "groups": ["header"] }
}
{% endschema %}
