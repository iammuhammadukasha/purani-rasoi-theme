{%- liquid
  assign menu = section.settings.menu
  if settings.logo != blank
    assign logo_src = settings.logo | image_url: width: 96
  else
    assign logo_src = 'logo-purani-rasoi.png' | asset_url
  endif
  assign brand1 = settings.brand_name_line1 | default: 'Purani'
  assign brand2 = settings.brand_name_line2 | default: 'Rasoi'
-%}

<header class="dh-header site-header">
  <div class="dh-header__inner">
    <button type="button" id="menu-open" class="site-header__menu-btn" aria-label="{{ 'general.accessibility.open_menu' | t }}">
      <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <a href="{{ routes.root_url }}" class="dh-logo" aria-label="{{ shop.name }} home">
      <img src="{{ logo_src }}" alt="" width="48" height="48">
      <span>
        <strong>{{ brand1 }}</strong>
        <em>{{ brand2 }}</em>
      </span>
    </a>

    <nav class="site-header__nav" aria-label="Primary">
      {%- if menu != blank -%}
        <ul class="dh-nav">
          {%- for link in linklists[menu].links -%}
            <li class="{% if link.links != blank %}relative{% endif %}">
              {%- if link.links != blank -%}
                <button
                  type="button"
                  id="shop-toggle"
                  class="dh-nav__btn{% if link.active %} is-active{% endif %}"
                  aria-expanded="false"
                  aria-controls="shop-menu"
                >
                  {{ link.title }}
                  <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
                <div id="shop-menu" class="shop-menu" hidden>
                  {%- for child in link.links -%}
                    <a href="{{ child.url }}">{{ child.title }}</a>
                  {%- endfor -%}
                </div>
              {%- else -%}
                <a href="{{ link.url }}" {% if link.active or link.current %}class="is-active"{% endif %}>{{ link.title }}</a>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      {%- else -%}
        <ul class="dh-nav">
          <li><a href="{{ routes.root_url }}" {% if request.page_type == 'index' %}class="is-active"{% endif %}>Home</a></li>
          <li class="relative">
            <button type="button" id="shop-toggle" class="dh-nav__btn" aria-expanded="false" aria-controls="shop-menu">
              Shop
              <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div id="shop-menu" class="shop-menu" hidden>
              <a href="{{ routes.all_products_collection_url }}">All Products</a>
              <a href="{{ routes.all_products_collection_url }}">Best Sellers</a>
            </div>
          </li>
          <li><a href="{{ routes.root_url }}#story">Our Story</a></li>
          <li><a href="{{ routes.root_url }}#blog">Recipes &amp; Blog</a></li>
          <li><a href="{{ routes.all_products_collection_url }}">Wholesale</a></li>
          <li><a href="{{ routes.root_url }}#contact">Contact</a></li>
        </ul>
      {%- endif -%}
    </nav>

    <div class="dh-tools">
      <a href="{{ routes.search_url }}" aria-label="{{ 'general.search' | t }}">
        <span class="material-symbols-outlined">search</span>
      </a>
      <a href="{% if shop.customer_accounts_enabled %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}" aria-label="{{ 'general.account' | t }}">
        <span class="material-symbols-outlined">person</span>
      </a>
      <a href="{{ routes.cart_url }}" class="dh-tools__cart" aria-label="{{ 'general.cart' | t }}">
        <span class="material-symbols-outlined">shopping_cart</span>
        <span class="cart-count cart-badge">{{ cart.item_count }}</span>
      </a>
    </div>
  </div>
</header>

<nav id="mobile-nav" class="mobile-nav" aria-label="Mobile">
  <button type="button" id="menu-close" class="mobile-nav__close" aria-label="{{ 'general.accessibility.close' | t }}">✕</button>
  {%- if menu != blank -%}
    {%- for link in linklists[menu].links -%}
      <a href="{{ link.url }}">{{ link.title }}</a>
      {%- for child in link.links -%}
        <a href="{{ child.url }}" style="padding-left:1rem;opacity:.85">{{ child.title }}</a>
      {%- endfor -%}
    {%- endfor -%}
  {%- else -%}
    <a href="{{ routes.root_url }}">Home</a>
    <a href="{{ routes.all_products_collection_url }}">Shop</a>
    <a href="{{ routes.root_url }}#story">Our Story</a>
    <a href="{{ routes.root_url }}#blog">Recipes &amp; Blog</a>
    <a href="{{ routes.all_products_collection_url }}">Wholesale</a>
    <a href="{{ routes.root_url }}#contact">Contact</a>
  {%- endif -%}
</nav>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ],
  "enabled_on": { "groups": ["header"] }
}
{% endschema %}
