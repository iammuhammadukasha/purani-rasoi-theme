{%- liquid
  assign heading = section.settings.heading | default: blog.title | default: 'Recipes & Blog'
  assign crumb = section.settings.crumb_label | default: 'Blog'
-%}

<section class="shop-banner blog-banner" aria-label="{{ heading | escape }}">
  {%- if section.settings.banner != blank -%}
    <img src="{{ section.settings.banner | image_url: width: 2000 }}" alt="" loading="eager" width="1600" height="600">
  {%- else -%}
    <img src="{{ 'banner-kitchen.png' | asset_url }}" alt="" loading="eager" width="1600" height="600">
  {%- endif -%}
  <div class="shop-banner__shade" aria-hidden="true"></div>
  <div class="shop-banner__content">
    <nav class="shop-banner__crumbs" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      <span aria-hidden="true">/</span>
      <span>{{ crumb }}</span>
    </nav>
    <h1>{{ heading }}</h1>
  </div>
</section>

{%- if section.settings.intro != blank -%}
  <p class="blog-index__intro">{{ section.settings.intro }}</p>
{%- endif -%}

<section class="blog-index" aria-label="{{ heading | escape }}">
  {%- paginate blog.articles by section.settings.articles_per_page -%}
    {%- if blog.articles_count == 0 -%}
      <p class="blog-index__empty">No articles yet. Check back soon.</p>
    {%- else -%}
      <div class="blog-index__grid">
        {%- for article in blog.articles -%}
          <article class="blog-card">
            <a href="{{ article.url }}" class="blog-card__media">
              {%- if article.image -%}
                <img
                  src="{{ article.image | image_url: width: 900 }}"
                  alt="{{ article.image.alt | default: article.title | escape }}"
                  width="600"
                  height="400"
                  loading="lazy"
                >
              {%- else -%}
                <img src="{{ 'story-kitchen.png' | asset_url }}" alt="" width="600" height="400" loading="lazy">
              {%- endif -%}
            </a>
            <div class="blog-card__body">
              {%- if article.tags.size > 0 -%}
                <p class="blog-card__meta">{{ article.tags.first }}</p>
              {%- elsif article.published_at -%}
                <p class="blog-card__meta">{{ article.published_at | date: '%d %b %Y' }}</p>
              {%- endif -%}
              <h2 class="blog-card__title">
                <a href="{{ article.url }}">{{ article.title }}</a>
              </h2>
              {%- if article.excerpt_or_content != blank -%}
                <p class="blog-card__excerpt">{{ article.excerpt_or_content | strip_html | truncatewords: 28 }}</p>
              {%- endif -%}
              <a href="{{ article.url }}" class="blog-card__more">Read More <span aria-hidden="true">→</span></a>
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if paginate.pages > 1 -%}
      <nav class="blog-index__pager" aria-label="Pagination">
        {%- if paginate.previous -%}
          <a href="{{ paginate.previous.url }}">‹ Previous</a>
        {%- endif -%}
        <span>{{ paginate.current_page }} / {{ paginate.pages }}</span>
        {%- if paginate.next -%}
          <a href="{{ paginate.next.url }}">Next ›</a>
        {%- endif -%}
      </nav>
    {%- endif -%}
  {%- endpaginate -%}
</section>

{% schema %}
{
  "name": "Blog listing",
  "settings": [
    { "type": "image_picker", "id": "banner", "label": "Banner image" },
    { "type": "text", "id": "heading", "label": "Banner title", "default": "Recipes & Blog" },
    { "type": "text", "id": "crumb_label", "label": "Breadcrumb label", "default": "Blog" },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro text",
      "default": "Tips, recipes, aur achar ki kahaniyan — ghar ke swaad ke saath."
    },
    { "type": "range", "id": "articles_per_page", "min": 4, "max": 24, "step": 2, "default": 8, "label": "Articles per page" }
  ]
}
{% endschema %}
