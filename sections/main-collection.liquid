{%- liquid
  assign heading = section.settings.heading | default: 'Our Shop'
  assign crumb = section.settings.crumb_label | default: 'Shop'
  assign current_sort = collection.sort_by | default: collection.default_sort_by
-%}

<section class="shop-banner" aria-label="{{ heading | escape }}">
  {%- if section.settings.banner != blank -%}
    <img src="{{ section.settings.banner | image_url: width: 2000 }}" alt="" loading="eager">
  {%- elsif collection.image -%}
    <img src="{{ collection.image | image_url: width: 2000 }}" alt="" loading="eager">
  {%- else -%}
    <img src="{{ 'hero-banner.png' | asset_url }}" alt="" loading="eager">
  {%- endif -%}
  <div class="shop-banner__shade" aria-hidden="true"></div>
  <div class="shop-banner__content">
    <h1>{{ heading }}</h1>
    <p class="shop-banner__crumbs">
      <a href="{{ routes.root_url }}">Home</a> &gt; {{ crumb }}
    </p>
  </div>
</section>

{%- if section.settings.show_trust -%}
  <section class="shop-usp" aria-label="Brand promises">
    {%- assign trust_n = 0 -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'trust' -%}
        {%- assign trust_n = trust_n | plus: 1 -%}
        {%- liquid
          case trust_n
            when 1
              assign trust_img = 'benefit-homemade.png' | asset_url
              assign trust_label = '100% Homemade'
            when 2
              assign trust_img = 'benefit-preservatives.png' | asset_url
              assign trust_label = 'No Preservatives'
            when 3
              assign trust_img = 'benefit-recipes.png' | asset_url
              assign trust_label = 'Traditional Recipes'
            else
              assign trust_img = 'benefit-love.png' | asset_url
              assign trust_label = 'Small Batch Made'
          endcase
          if block.settings.label != blank
            assign trust_label = block.settings.label
          endif
        -%}
        <div class="shop-usp__item" {{ block.shopify_attributes }}>
          <span class="shop-usp__icon" aria-hidden="true">
            <img src="{{ trust_img }}" alt="" width="120" height="120" loading="lazy">
          </span>
          <h3 class="shop-usp__title">{{ trust_label }}</h3>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </section>
{%- endif -%}

<div class="shop-toolbar">
  <div class="shop-toolbar__inner">
    <div class="shop-toolbar__left">
      <button type="button" class="shop-toolbar__btn" data-shop-filter aria-expanded="false" aria-controls="shop-filters">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 5h16l-6.5 7.2V19l-3 1.5v-8.3L4 5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
        </svg>
        <span>Filter</span>
      </button>

      <div class="shop-toolbar__sort" data-shop-sort>
        <button type="button" class="shop-toolbar__btn" data-shop-sort-toggle aria-expanded="false" aria-haspopup="listbox">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 3l3.2 5.5H8.8L12 3zM12 21l-3.2-5.5h6.4L12 21zM3 12l5.5-3.2v6.4L3 12zM21 12l-5.5 3.2V8.8L21 12z" fill="currentColor"/>
          </svg>
          <span>Sort</span>
          <svg width="12" height="14" viewBox="0 0 12 16" fill="none" aria-hidden="true">
            <path d="M6 1v14M6 1L3 4M6 1l3 3M6 15l-3-3M6 15l3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="shop-sort__menu" role="listbox" aria-label="Sort products" hidden>
          {%- for option in collection.sort_options -%}
            <a
              href="{{ collection.url }}?sort_by={{ option.value }}"
              class="shop-sort__option{% if option.value == current_sort %} is-active{% endif %}"
              data-sort-value="{{ option.value }}"
              role="option"
              {% if option.value == current_sort %}aria-selected="true"{% endif %}
            >
              {{ option.name }}
            </a>
          {%- endfor -%}
        </div>
      </div>
    </div>

    <div class="shop-toolbar__views" role="group" aria-label="Product layout">
      <button type="button" class="shop-toolbar__view is-active" data-shop-view="grid" aria-pressed="true" aria-label="Grid view">
        <span class="material-symbols-outlined" aria-hidden="true">grid_view</span>
      </button>
      <button type="button" class="shop-toolbar__view" data-shop-view="list" aria-pressed="false" aria-label="List view">
        <span class="material-symbols-outlined" aria-hidden="true">view_list</span>
      </button>
    </div>
  </div>
</div>

<div class="shop-filters" id="shop-filters" hidden>
  <div class="shop-filters__backdrop" data-shop-filter-close tabindex="-1"></div>
  <aside class="shop-filters__panel" role="dialog" aria-modal="true" aria-labelledby="shop-filters-title">
    <div class="shop-filters__head">
      <h2 id="shop-filters-title">Filter</h2>
      <button type="button" class="shop-filters__close" data-shop-filter-close aria-label="Close filters">✕</button>
    </div>
    <form class="shop-filters__form" method="get" action="{{ collection.url }}">
      {%- if current_sort != blank -%}
        <input type="hidden" name="sort_by" value="{{ current_sort }}">
      {%- endif -%}

      {%- assign has_filters = false -%}
      {%- if collection.filters.size > 0 -%}
        {%- assign has_filters = true -%}
        {%- for filter in collection.filters -%}
          <div class="shop-filters__group">
            <h3>{{ filter.label }}</h3>
            {%- case filter.type -%}
              {%- when 'list', 'boolean' -%}
                {%- for value in filter.values -%}
                  <label {% if value.count == 0 and value.active == false %}class="is-disabled"{% endif %}>
                    <input
                      type="checkbox"
                      name="{{ value.param_name }}"
                      value="{{ value.value }}"
                      {% if value.active %}checked{% endif %}
                      {% if value.count == 0 and value.active == false %}disabled{% endif %}
                    >
                    {{ value.label }}{% if value.count %} ({{ value.count }}){% endif %}
                  </label>
                {%- endfor -%}
              {%- when 'price_range' -%}
                <div class="shop-filters__price-row">
                  <span>Min</span>
                  <input
                    type="number"
                    name="{{ filter.min_value.param_name }}"
                    value="{{ filter.min_value.value | default: 0 | money_without_currency | replace: ',', '' }}"
                    placeholder="0"
                    min="0"
                    aria-label="Minimum price"
                  >
                </div>
                <div class="shop-filters__price-row">
                  <span>Max</span>
                  <input
                    type="number"
                    name="{{ filter.max_value.param_name }}"
                    value="{% if filter.max_value.value %}{{ filter.max_value.value | money_without_currency | replace: ',', '' }}{% else %}{{ filter.range_max | money_without_currency | replace: ',', '' }}{% endif %}"
                    placeholder="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                    min="0"
                    aria-label="Maximum price"
                  >
                </div>
            {%- endcase -%}
          </div>
        {%- endfor -%}
      {%- endif -%}

      {%- unless has_filters -%}
        <div class="shop-filters__group">
          <h3>Availability</h3>
          <label>
            <input type="checkbox" name="filter.v.availability" value="1">
            In stock
          </label>
        </div>
        <div class="shop-filters__group">
          <h3>Price</h3>
          <div class="shop-filters__price-row">
            <span>Min</span>
            <input type="number" name="filter.v.price.gte" value="0" min="0" aria-label="Minimum price">
          </div>
          <div class="shop-filters__price-row">
            <span>Max</span>
            <input type="number" name="filter.v.price.lte" value="" min="0" placeholder="999" aria-label="Maximum price">
          </div>
        </div>
      {%- endunless -%}

      <div class="shop-filters__actions">
        <a class="shop-filters__clear" href="{{ collection.url }}">Clear</a>
        <button type="submit" class="shop-filters__apply">Apply</button>
      </div>
    </form>
  </aside>
</div>

<section class="shop-grid" aria-label="Products" id="product-grid">
  {%- paginate collection.products by section.settings.products_per_page -%}
    {%- for product in collection.products -%}
      {% render 'product-card', product: product, show_rating: true %}
    {%- else -%}
      <p style="grid-column:1/-1;text-align:center;padding:3rem">No products found in this collection.</p>
    {%- endfor -%}

    {%- if paginate.pages > 1 -%}
      <nav class="pagination" style="grid-column:1/-1;display:flex;gap:0.5rem;justify-content:center;padding:2rem">
        {%- if paginate.previous -%}
          <a href="{{ paginate.previous.url }}">← Prev</a>
        {%- endif -%}
        <span>Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
        {%- if paginate.next -%}
          <a href="{{ paginate.next.url }}">Next →</a>
        {%- endif -%}
      </nav>
    {%- endif -%}
  {%- endpaginate -%}
</section>

{%- if section.settings.show_promise -%}
  {%- assign promise_count = 0 -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'promise' -%}
      {%- assign promise_count = promise_count | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}
  <section class="shop-promise" aria-label="Our promises">
    <div class="shop-promise__inner">
      {%- if promise_count > 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'promise' -%}
            <div class="shop-promise__item" {{ block.shopify_attributes }}>
              <span class="shop-promise__icon material-symbols-outlined" aria-hidden="true">{{ block.settings.icon }}</span>
              <span>{{ block.settings.label }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        <div class="shop-promise__item">
          <span class="shop-promise__icon material-symbols-outlined" aria-hidden="true">emoji_people</span>
          <span>Made with Tradition</span>
        </div>
        <div class="shop-promise__item">
          <span class="shop-promise__icon material-symbols-outlined" aria-hidden="true">wb_sunny</span>
          <span>Sun Dried &amp; Natural</span>
        </div>
        <div class="shop-promise__item">
          <span class="shop-promise__icon material-symbols-outlined" aria-hidden="true">spa</span>
          <span>Premium Ingredients</span>
        </div>
        <div class="shop-promise__item">
          <span class="shop-promise__icon material-symbols-outlined" aria-hidden="true">verified_user</span>
          <span>Hygienically Packed</span>
        </div>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Collection products",
  "settings": [
    { "type": "text", "id": "heading", "label": "Banner heading", "default": "Our Shop" },
    { "type": "text", "id": "crumb_label", "label": "Breadcrumb label", "default": "Shop" },
    { "type": "image_picker", "id": "banner", "label": "Banner image" },
    { "type": "checkbox", "id": "show_trust", "label": "Show trust badges under hero", "default": true },
    { "type": "checkbox", "id": "show_promise", "label": "Show promise strip above footer", "default": true },
    { "type": "range", "id": "products_per_page", "min": 8, "max": 36, "step": 4, "label": "Products per page", "default": 16 }
  ],
  "blocks": [
    {
      "type": "trust",
      "name": "Trust badge",
      "settings": [
        { "type": "text", "id": "label", "label": "Heading", "default": "100% Homemade" },
        { "type": "image_picker", "id": "image", "label": "Icon image" },
        { "type": "text", "id": "fallback_asset", "label": "Fallback asset filename", "default": "benefit-homemade.png" },
        { "type": "text", "id": "icon", "label": "Legacy icon name (unused)", "default": "soup_kitchen" }
      ]
    },
    {
      "type": "promise",
      "name": "Promise item",
      "settings": [
        { "type": "text", "id": "icon", "label": "Material icon name", "default": "wb_sunny" },
        { "type": "text", "id": "label", "label": "Label", "default": "Sun Dried & Natural" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection products",
      "blocks": [
        { "type": "trust", "settings": { "label": "100% Homemade", "fallback_asset": "benefit-homemade.png" } },
        { "type": "trust", "settings": { "label": "No Preservatives", "fallback_asset": "benefit-preservatives.png" } },
        { "type": "trust", "settings": { "label": "Traditional Recipes", "fallback_asset": "benefit-recipes.png" } },
        { "type": "trust", "settings": { "label": "Small Batch Made", "fallback_asset": "benefit-love.png" } },
        { "type": "promise", "settings": { "icon": "emoji_people", "label": "Made with Tradition" } },
        { "type": "promise", "settings": { "icon": "wb_sunny", "label": "Sun Dried & Natural" } },
        { "type": "promise", "settings": { "icon": "spa", "label": "Premium Ingredients" } },
        { "type": "promise", "settings": { "icon": "verified_user", "label": "Hygienically Packed" } }
      ]
    }
  ]
}
{% endschema %}
