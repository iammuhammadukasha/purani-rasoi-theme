{%- liquid
  assign heading = section.settings.heading | default: 'Our Shop'
  assign crumb = section.settings.crumb_label | default: 'Shop'
-%}

<section class="shop-banner" aria-label="{{ heading | escape }}">
  {%- if section.settings.banner != blank -%}
    <img src="{{ section.settings.banner | image_url: width: 2000 }}" alt="" loading="eager">
  {%- elsif collection.image -%}
    <img src="{{ collection.image | image_url: width: 2000 }}" alt="" loading="eager">
  {%- else -%}
    <img src="{{ 'hero-banner.png' | asset_url }}" alt="" loading="eager">
  {%- endif -%}
  <div class="shop-banner__shade" aria-hidden="true"></div>
  <div class="shop-banner__content">
    <h1>{{ heading }}</h1>
    <p class="shop-banner__crumbs">
      <a href="{{ routes.root_url }}">Home</a> &gt; {{ crumb }}
    </p>
  </div>
</section>

{%- if section.settings.show_trust -%}
  <section class="shop-usp" aria-label="Brand promises">
    {%- for block in section.blocks -%}
      {%- if block.type == 'trust' -%}
        <div class="shop-usp__item" {{ block.shopify_attributes }}>
          <span class="shop-usp__icon material-symbols-outlined" aria-hidden="true">{{ block.settings.icon }}</span>
          <span>{{ block.settings.label }}</span>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </section>
{%- endif -%}

<div class="shop-toolbar">
  <div class="shop-toolbar__inner">
    <div class="shop-toolbar__left">
      <button type="button" class="shop-toolbar__btn" data-shop-filter aria-expanded="false" aria-controls="shop-filters">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 5h16l-6.5 7.2V19l-3 1.5v-8.3L4 5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
        </svg>
        <span>Filter</span>
      </button>

      <div class="shop-toolbar__sort">
        <form>
          <label class="shop-toolbar__btn shop-toolbar__sort-trigger">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 3l3.2 5.5H8.8L12 3zM12 21l-3.2-5.5h6.4L12 21zM3 12l5.5-3.2v6.4L3 12zM21 12l-5.5 3.2V8.8L21 12z" fill="currentColor"/>
            </svg>
            <span>Sort</span>
            <svg width="12" height="14" viewBox="0 0 12 16" fill="none" aria-hidden="true">
              <path d="M6 1v14M6 1L3 4M6 1l3 3M6 15l-3-3M6 15l3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <select
              class="shop-toolbar__select"
              name="sort_by"
              aria-label="Sort products"
              onchange="this.form.submit()"
            >
              {%- for option in collection.sort_options -%}
                <option value="{{ option.value }}" {% if option.value == collection.sort_by %}selected{% endif %}>
                  {{ option.name }}
                </option>
              {%- endfor -%}
            </select>
          </label>
        </form>
      </div>
    </div>

    <div class="shop-toolbar__views" role="group" aria-label="Product layout">
      <button type="button" class="shop-toolbar__view is-active" data-shop-view="grid" aria-pressed="true" aria-label="Grid view">
        <span class="material-symbols-outlined" aria-hidden="true">grid_view</span>
      </button>
      <button type="button" class="shop-toolbar__view" data-shop-view="list" aria-pressed="false" aria-label="List view">
        <span class="material-symbols-outlined" aria-hidden="true">view_list</span>
      </button>
    </div>
  </div>
</div>

<div class="shop-filters" id="shop-filters" hidden>
  <div class="shop-filters__backdrop" data-shop-filter-close tabindex="-1"></div>
  <aside class="shop-filters__panel" role="dialog" aria-modal="true" aria-labelledby="shop-filters-title">
    <div class="shop-filters__head">
      <h2 id="shop-filters-title">Filter</h2>
      <button type="button" class="shop-filters__close" data-shop-filter-close aria-label="Close filters">✕</button>
    </div>
    <form class="shop-filters__form">
      {%- if collection.filters.size > 0 -%}
        {%- for filter in collection.filters -%}
          <div class="shop-filters__group">
            <h3>{{ filter.label }}</h3>
            {%- case filter.type -%}
              {%- when 'list', 'boolean' -%}
                {%- for value in filter.values -%}
                  <label>
                    <input
                      type="checkbox"
                      name="{{ value.param_name }}"
                      value="{{ value.value }}"
                      {% if value.active %}checked{% endif %}
                      {% if value.count == 0 and value.active == false %}disabled{% endif %}
                    >
                    {{ value.label }}{% if value.count %} ({{ value.count }}){% endif %}
                  </label>
                {%- endfor -%}
              {%- when 'price_range' -%}
                <label>
                  Min
                  <input
                    type="number"
                    name="{{ filter.min_value.param_name }}"
                    value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"
                    placeholder="0"
                    min="0"
                  >
                </label>
                <label>
                  Max
                  <input
                    type="number"
                    name="{{ filter.max_value.param_name }}"
                    value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"
                    placeholder="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                    min="0"
                  >
                </label>
            {%- endcase -%}
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="shop-filters__group">
          <h3>Availability</h3>
          <label><input type="checkbox" name="filter.v.availability" value="1"> In stock</label>
        </div>
        <p style="font-family:Work Sans,sans-serif;font-size:0.8125rem;opacity:0.75;margin:0 0 1rem">
          Enable storefront filters in Shopify Admin → Settings → Apps and sales channels → Online Store → Preferences for more options.
        </p>
      {%- endif -%}
      <div class="shop-filters__actions">
        <a class="shop-filters__clear" href="{{ collection.url }}" style="text-align:center;text-decoration:none;line-height:1.2;display:flex;align-items:center;justify-content:center">Clear</a>
        <button type="submit" class="shop-filters__apply">Apply</button>
      </div>
    </form>
  </aside>
</div>

<section class="shop-grid" aria-label="Products" id="product-grid">
  {%- paginate collection.products by section.settings.products_per_page -%}
    {%- for product in collection.products -%}
      {% render 'product-card', product: product, show_rating: true %}
    {%- else -%}
      <p style="grid-column:1/-1;text-align:center;padding:3rem">No products found in this collection.</p>
    {%- endfor -%}

    {%- if paginate.pages > 1 -%}
      <nav class="pagination" style="grid-column:1/-1;display:flex;gap:0.5rem;justify-content:center;padding:2rem">
        {%- if paginate.previous -%}
          <a href="{{ paginate.previous.url }}">← Prev</a>
        {%- endif -%}
        <span>Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
        {%- if paginate.next -%}
          <a href="{{ paginate.next.url }}">Next →</a>
        {%- endif -%}
      </nav>
    {%- endif -%}
  {%- endpaginate -%}
</section>

{% schema %}
{
  "name": "Collection products",
  "settings": [
    { "type": "text", "id": "heading", "label": "Banner heading", "default": "Our Shop" },
    { "type": "text", "id": "crumb_label", "label": "Breadcrumb label", "default": "Shop" },
    { "type": "image_picker", "id": "banner", "label": "Banner image" },
    { "type": "checkbox", "id": "show_trust", "label": "Show trust badges", "default": true },
    { "type": "range", "id": "products_per_page", "min": 8, "max": 36, "step": 4, "label": "Products per page", "default": 16 }
  ],
  "blocks": [
    {
      "type": "trust",
      "name": "Trust badge",
      "settings": [
        { "type": "text", "id": "icon", "label": "Material icon name", "default": "soup_kitchen" },
        { "type": "html", "id": "label", "label": "Label (use <br> for line break)", "default": "100%<br>Homemade" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection products",
      "blocks": [
        { "type": "trust", "settings": { "icon": "soup_kitchen", "label": "100%<br>Homemade" } },
        { "type": "trust", "settings": { "icon": "science", "label": "No<br>Preservatives" } },
        { "type": "trust", "settings": { "icon": "skillet", "label": "Small Batch<br>Mode" } },
        { "type": "trust", "settings": { "icon": "shopping_bag", "label": "Secure<br>Packaging" } }
      ]
    }
  ]
}
{% endschema %}
