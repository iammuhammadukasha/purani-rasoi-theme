{%- liquid
  assign heading = section.settings.heading | default: 'Our Shop'
  assign crumb = section.settings.crumb_label | default: 'Shop'
-%}

<section class="shop-banner" aria-label="{{ heading | escape }}">
  {%- if section.settings.banner != blank -%}
    <img src="{{ section.settings.banner | image_url: width: 2000 }}" alt="" loading="eager">
  {%- elsif collection.image -%}
    <img src="{{ collection.image | image_url: width: 2000 }}" alt="" loading="eager">
  {%- else -%}
    <img src="{{ 'hero-banner.png' | asset_url }}" alt="" loading="eager">
  {%- endif -%}
  <div class="shop-banner__shade" aria-hidden="true"></div>
  <div class="shop-banner__content">
    <h1>{{ heading }}</h1>
    <p class="shop-banner__crumbs">
      <a href="{{ routes.root_url }}">Home</a> &gt; {{ crumb }}
    </p>
  </div>
</section>

{%- if section.settings.show_trust -%}
  <section class="shop-usp" aria-label="Brand promises">
    {%- for block in section.blocks -%}
      {%- if block.type == 'trust' -%}
        <div class="shop-usp__item" {{ block.shopify_attributes }}>
          <span class="shop-usp__icon material-symbols-outlined" aria-hidden="true">{{ block.settings.icon }}</span>
          <span>{{ block.settings.label }}</span>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </section>
{%- endif -%}

<div class="shop-toolbar">
  <div class="shop-toolbar__left">
    <form class="shop-sort">
      <label>
        <span class="sr-only">Sort</span>
        <select name="sort_by" aria-label="Sort products" onchange="this.form.submit()">
          {%- for option in collection.sort_options -%}
            <option value="{{ option.value }}" {% if option.value == collection.sort_by %}selected{% endif %}>
              {{ option.name }}
            </option>
          {%- endfor -%}
        </select>
      </label>
    </form>
  </div>
  <div class="shop-toolbar__right">
    <span class="shop-count">{{ collection.products_count }} products</span>
  </div>
</div>

<section class="shop-grid" aria-label="Products" id="product-grid">
  {%- paginate collection.products by section.settings.products_per_page -%}
    {%- for product in collection.products -%}
      {% render 'product-card', product: product, show_rating: true %}
    {%- else -%}
      <p style="grid-column:1/-1;text-align:center;padding:3rem">No products found in this collection.</p>
    {%- endfor -%}

    {%- if paginate.pages > 1 -%}
      <nav class="pagination" style="grid-column:1/-1;display:flex;gap:0.5rem;justify-content:center;padding:2rem">
        {%- if paginate.previous -%}
          <a href="{{ paginate.previous.url }}">← Prev</a>
        {%- endif -%}
        <span>Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
        {%- if paginate.next -%}
          <a href="{{ paginate.next.url }}">Next →</a>
        {%- endif -%}
      </nav>
    {%- endif -%}
  {%- endpaginate -%}
</section>

{% schema %}
{
  "name": "Collection products",
  "settings": [
    { "type": "text", "id": "heading", "label": "Banner heading", "default": "Our Shop" },
    { "type": "text", "id": "crumb_label", "label": "Breadcrumb label", "default": "Shop" },
    { "type": "image_picker", "id": "banner", "label": "Banner image" },
    { "type": "checkbox", "id": "show_trust", "label": "Show trust badges", "default": true },
    { "type": "range", "id": "products_per_page", "min": 8, "max": 36, "step": 4, "label": "Products per page", "default": 16 }
  ],
  "blocks": [
    {
      "type": "trust",
      "name": "Trust badge",
      "settings": [
        { "type": "text", "id": "icon", "label": "Material icon name", "default": "soup_kitchen" },
        { "type": "html", "id": "label", "label": "Label (use <br> for line break)", "default": "100%<br>Homemade" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection products",
      "blocks": [
        { "type": "trust", "settings": { "icon": "soup_kitchen", "label": "100%<br>Homemade" } },
        { "type": "trust", "settings": { "icon": "science", "label": "No<br>Preservatives" } },
        { "type": "trust", "settings": { "icon": "skillet", "label": "Small Batch<br>Mode" } },
        { "type": "trust", "settings": { "icon": "shopping_bag", "label": "Secure<br>Packaging" } }
      ]
    }
  ]
}
{% endschema %}
