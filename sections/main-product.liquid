{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_form_id = 'product-form-' | append: section.id
  assign brand_name = section.settings.brand_eyebrow | default: shop.name
  assign delivery_text = section.settings.delivery_text | default: 'Delivery in 3-5 Days'
  assign rating_text = section.settings.rating_text | default: '4.9 (428 Reviews)'
  assign orders_text = section.settings.orders_text | default: '2500+ Orders'
  assign promo_heading = section.settings.promo_heading | default: 'Buy 2 Get Free Shipping'
  assign compare_heading = section.settings.compare_heading | default: 'Why Choose Purani Rasoi?'
  assign compare_sub = section.settings.compare_subtext | default: 'Experience the true taste of tradition'
-%}

<div class="pdp" data-pdp data-section-id="{{ section.id }}">
  <div class="pdp__inner max-w-site mx-auto">
    <nav class="pdp-crumbs" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      <span aria-hidden="true">›</span>
      <a href="{{ routes.all_products_collection_url }}">Shop</a>
      {%- if product.collections.first -%}
        <span aria-hidden="true">›</span>
        <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a>
      {%- endif -%}
      <span aria-hidden="true">›</span>
      <span aria-current="page">{{ product.title }}</span>
    </nav>

    <div class="pdp-layout">
      <section class="pdp-gallery" aria-label="Product images">
        <div class="pdp-gallery__stage">
          {%- if product.media.size > 1 -%}
            <div class="pdp-thumbs" role="list" data-thumbs-rail>
              {%- for media in product.media -%}
                <button
                  type="button"
                  class="pdp-thumbs__item{% if forloop.first %} is-active{% endif %}"
                  data-thumb="{{ media | image_url: width: 1400 }}"
                  aria-label="View image {{ forloop.index }}"
                >
                  <img src="{{ media | image_url: width: 200 }}" alt="" loading="lazy" width="80" height="80">
                </button>
              {%- endfor -%}
            </div>
          {%- endif -%}

          <div class="pdp-gallery__main">
            {%- if product.selected_or_first_available_variant.featured_media != blank -%}
              {%- assign featured = product.selected_or_first_available_variant.featured_media -%}
            {%- else -%}
              {%- assign featured = product.featured_media -%}
            {%- endif -%}
            {%- if featured -%}
              <img
                id="pdp-main-img"
                src="{{ featured | image_url: width: 1400 }}"
                alt="{{ featured.alt | escape | default: product.title | escape }}"
                width="800"
                height="800"
              >
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'pdp-placeholder' }}
            {%- endif -%}
            <button type="button" class="pdp-wish" aria-label="Add to wishlist" data-wishlist>
              <span class="material-symbols-outlined" aria-hidden="true">favorite</span>
            </button>
          </div>
        </div>

        {%- assign cert_count = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'media_cert' -%}{%- assign cert_count = cert_count | plus: 1 -%}{%- endif -%}
        {%- endfor -%}
        {%- if cert_count > 0 -%}
          <div class="pdp-media-certs">
            {%- for block in section.blocks -%}
              {%- if block.type == 'media_cert' -%}
                <div class="pdp-media-certs__item" {{ block.shopify_attributes }}>
                  <span class="material-symbols-outlined" aria-hidden="true">{{ block.settings.icon }}</span>
                  <span>{{ block.settings.label }}</span>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </section>

      <section class="pdp-body">
        <p class="pdp-brand">{{ brand_name }}</p>
        <h1 class="pdp-title">{{ product.title }}</h1>

        {%- assign tag_count = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'attribute_tag' -%}{%- assign tag_count = tag_count | plus: 1 -%}{%- endif -%}
        {%- endfor -%}
        {%- if tag_count > 0 -%}
          <div class="pdp-tags">
            {%- for block in section.blocks -%}
              {%- if block.type == 'attribute_tag' -%}
                <span class="pdp-tags__item" {{ block.shopify_attributes }}>
                  <span class="material-symbols-outlined" aria-hidden="true">{{ block.settings.icon }}</span>
                  {{ block.settings.label }}
                </span>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}

        <div class="pdp-meta">
          <div class="pdp-meta__rating">
            <span class="pdp-meta__stars" aria-hidden="true">★★★★★</span>
            <span class="pdp-meta__count">{{ rating_text }}</span>
          </div>
          {%- if orders_text != blank -%}
            <span class="pdp-meta__orders">{{ orders_text }}</span>
          {%- endif -%}
        </div>

        {% form 'product', product, id: product_form_id, class: 'product-form', data-product-form: '' %}
          <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id>

          <div class="pdp-price" id="price-{{ section.id }}" data-pdp-price>
            <div class="pdp-price__row">
              <strong data-price-current>{{ current_variant.price | money }}</strong>
              {%- if current_variant.compare_at_price > current_variant.price -%}
                <s data-price-compare>{{ current_variant.compare_at_price | money }}</s>
                {%- assign save = current_variant.compare_at_price | minus: current_variant.price | times: 100.0 | divided_by: current_variant.compare_at_price | round -%}
                <span class="pdp-price__off" data-price-off>{{ save }}% OFF</span>
              {%- endif -%}
            </div>
            <p class="pdp-price__tax">(Inclusive of all taxes)</p>
          </div>

          <div class="pdp-availability">
            {%- if product.available -%}
              <span class="pdp-stock" data-pdp-stock>
                <span class="material-symbols-outlined" aria-hidden="true">check_circle</span>
                In Stock
              </span>
            {%- else -%}
              <span class="pdp-stock pdp-stock--out" data-pdp-stock>Sold out</span>
            {%- endif -%}
            {%- if delivery_text != blank -%}
              <span class="pdp-delivery">
                <span class="material-symbols-outlined" aria-hidden="true">local_shipping</span>
                {{ delivery_text }}
              </span>
            {%- endif -%}
          </div>

          <div class="pdp-opts">
            {%- unless product.has_only_default_variant -%}
              {%- for option in product.options_with_values -%}
                <div class="pdp-opts__group">
                  <span class="pdp-label">Select {{ option.name }}</span>
                  <div class="pdp-weights" role="group" aria-label="{{ option.name }}">
                    {%- for value in option.values -%}
                      <button
                        type="button"
                        data-option-value="{{ value | escape }}"
                        data-option-name="{{ option.name | escape }}"
                        data-option-position="{{ option.position }}"
                        {% if option.selected_value == value %}class="is-active"{% endif %}
                      >{{ value }}</button>
                    {%- endfor -%}
                  </div>
                  <select
                    id="Option-{{ section.id }}-{{ forloop.index0 }}"
                    name="options[{{ option.name | escape }}]"
                    data-option-position="{{ option.position }}"
                    class="sr-only"
                  >
                    {%- for value in option.values -%}
                      <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>{{ value }}</option>
                    {%- endfor -%}
                  </select>
                </div>
              {%- endfor -%}
            {%- endunless -%}

            <div class="pdp-opts__group">
              <span class="pdp-label">Quantity</span>
              <div class="pdp-qty" aria-label="{{ 'products.product.quantity' | t }}">
                <button type="button" data-qty-minus aria-label="Decrease quantity">−</button>
                <input
                  id="Quantity-product"
                  type="number"
                  name="quantity"
                  value="1"
                  min="1"
                  class="sr-only"
                  data-qty-input
                >
                <span data-qty-value>1</span>
                <button type="button" data-qty-plus aria-label="Increase quantity">+</button>
              </div>
            </div>
          </div>

          <div class="pdp-ctas">
            <button
              type="submit"
              class="pdp-add"
              name="add"
              data-add-to-cart
              {% unless current_variant.available %}disabled{% endunless %}
            >
              <span class="material-symbols-outlined" aria-hidden="true">shopping_cart</span>
              {%- if current_variant.available -%}
                ADD TO CART
              {%- else -%}
                {{ 'products.product.sold_out' | t }}
              {%- endif -%}
            </button>
            <button
              type="submit"
              class="pdp-buy"
              name="add"
              data-buy-now
              {% unless current_variant.available %}disabled{% endunless %}
            >
              <span class="material-symbols-outlined" aria-hidden="true">bolt</span>
              BUY NOW
            </button>
          </div>
        {% endform %}

        {%- assign trust_count = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'trust' -%}{%- assign trust_count = trust_count | plus: 1 -%}{%- endif -%}
        {%- endfor -%}
        {%- if trust_count > 0 -%}
          <div class="pdp-trust">
            {%- for block in section.blocks -%}
              {%- if block.type == 'trust' -%}
                <div class="pdp-trust__item" {{ block.shopify_attributes }}>
                  <span class="material-symbols-outlined" aria-hidden="true">{{ block.settings.icon }}</span>
                  <span class="pdp-trust__text">
                    <span class="pdp-trust__title">{{ block.settings.label }}</span>
                    {%- if block.settings.sublabel != blank -%}
                      <span class="pdp-trust__sub">{{ block.settings.sublabel }}</span>
                    {%- endif -%}
                  </span>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </section>
    </div>

    {%- assign feature_count = 0 -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'feature' -%}{%- assign feature_count = feature_count | plus: 1 -%}{%- endif -%}
    {%- endfor -%}
    {%- if feature_count > 0 -%}
      <section class="pdp-features" aria-label="Key features">
        {%- for block in section.blocks -%}
          {%- if block.type == 'feature' -%}
            <div class="pdp-features__item" {{ block.shopify_attributes }}>
              <span class="pdp-features__icon material-symbols-outlined" aria-hidden="true">{{ block.settings.icon }}</span>
              <span class="pdp-features__label">{{ block.settings.label }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </section>
    {%- endif -%}

    {%- assign compare_count = 0 -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'compare_row' -%}{%- assign compare_count = compare_count | plus: 1 -%}{%- endif -%}
    {%- endfor -%}

    {%- if compare_count > 0 -%}
      <section class="pdp-compare" aria-labelledby="Compare-{{ section.id }}">
        <div class="pdp-compare__intro">
          <h2 id="Compare-{{ section.id }}" class="pdp-compare__heading">
            <span class="material-symbols-outlined" aria-hidden="true">eco</span>
            {{ compare_heading }}
          </h2>
          {%- if compare_sub != blank -%}
            <p class="pdp-compare__sub">{{ compare_sub }}</p>
          {%- endif -%}
        </div>
        <div class="pdp-compare__vs">
          <div class="pdp-compare__col pdp-compare__col--us">
            <h3>Purani Rasoi</h3>
            <ul>
              {%- for block in section.blocks -%}
                {%- if block.type == 'compare_row' -%}
                  <li {{ block.shopify_attributes }}>
                    <span class="material-symbols-outlined pdp-compare__yes" aria-hidden="true">check_circle</span>
                    <span>{{ block.settings.us_text | default: block.settings.label }}</span>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>
          <div class="pdp-compare__badge" aria-hidden="true">VS</div>
          <div class="pdp-compare__col pdp-compare__col--them">
            <h3>Other Brands</h3>
            <ul>
              {%- for block in section.blocks -%}
                {%- if block.type == 'compare_row' -%}
                  <li {{ block.shopify_attributes }}>
                    <span class="material-symbols-outlined pdp-compare__no" aria-hidden="true">cancel</span>
                    <span>{{ block.settings.them_text | default: '—' }}</span>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>
        </div>
      </section>
    {%- endif -%}

    {%- comment -%} Always under Why Choose — use theme blocks when present, else defaults {%- endcomment -%}
    {%- assign review_blocks = section.blocks | where: 'type', 'review' -%}
    {%- assign review_heading_m = section.settings.reviews_heading_mobile | default: 'Customer Reviews' -%}
    {%- assign review_heading_d = section.settings.reviews_heading | default: 'What Our Customers Say' -%}
    <section class="pr-reviews pdp-reviews" aria-labelledby="Reviews-{{ section.id }}">
      <div
        class="mh-section mh-section--soft home-mobile love-carousel"
        data-love-carousel
        data-interval="{{ section.settings.reviews_interval | default: 4000 }}"
      >
        <h2 id="Reviews-{{ section.id }}" class="mh-heading">{{ review_heading_m }}</h2>
        <div class="love-carousel__viewport">
          {%- if review_blocks.size > 0 -%}
            {%- for block in review_blocks -%}
              <blockquote
                class="mh-love love-carousel__slide{% if forloop.first %} is-active{% endif %}"
                data-love-slide
                aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
                {{ block.shopify_attributes }}
              >
                <div class="mh-love__stars" aria-hidden="true">★★★★★</div>
                <p>{{ block.settings.quote }}</p>
                <footer>
                  {%- if block.settings.avatar != blank -%}
                    <img src="{{ block.settings.avatar | image_url: width: 72 }}" alt="" width="36" height="36" loading="lazy">
                  {%- else -%}
                    <img src="{{ 'logo-purani-rasoi.png' | asset_url }}" alt="" width="36" height="36" loading="lazy">
                  {%- endif -%}
                  <cite>{{ block.settings.author }}</cite>
                </footer>
              </blockquote>
            {%- endfor -%}
          {%- else -%}
            <blockquote class="mh-love love-carousel__slide is-active" data-love-slide aria-hidden="false">
              <div class="mh-love__stars" aria-hidden="true">★★★★★</div>
              <p>“Aam ka achar bilkul ghar jaisa swad. Quality aur packaging dono hi best!”</p>
              <footer>
                <img src="{{ 'logo-purani-rasoi.png' | asset_url }}" alt="" width="36" height="36" loading="lazy">
                <cite>Priya Sharma</cite>
              </footer>
            </blockquote>
            <blockquote class="mh-love love-carousel__slide" data-love-slide aria-hidden="true">
              <div class="mh-love__stars" aria-hidden="true">★★★★★</div>
              <p>“Nimbu ka achar try kiya, bahut hi tasty aur fresh. Will order again!”</p>
              <footer>
                <img src="{{ 'logo-purani-rasoi.png' | asset_url }}" alt="" width="36" height="36" loading="lazy">
                <cite>Rohit Verma</cite>
              </footer>
            </blockquote>
            <blockquote class="mh-love love-carousel__slide" data-love-slide aria-hidden="true">
              <div class="mh-love__stars" aria-hidden="true">★★★★★</div>
              <p>“Best achar I have ever had. 100% recommended!”</p>
              <footer>
                <img src="{{ 'logo-purani-rasoi.png' | asset_url }}" alt="" width="36" height="36" loading="lazy">
                <cite>Neha Agarwal</cite>
              </footer>
            </blockquote>
          {%- endif -%}
        </div>
        <div class="mh-dots" data-love-dots role="tablist" aria-label="Testimonials">
          {%- if review_blocks.size > 0 -%}
            {%- for block in review_blocks -%}
              <button
                type="button"
                class="mh-dots__dot{% if forloop.first %} is-active{% endif %}"
                data-love-dot="{{ forloop.index0 }}"
                aria-label="Show review {{ forloop.index }}"
                {% if forloop.first %}aria-current="true"{% endif %}
              ></button>
            {%- endfor -%}
          {%- else -%}
            <button type="button" class="mh-dots__dot is-active" data-love-dot="0" aria-label="Show review 1" aria-current="true"></button>
            <button type="button" class="mh-dots__dot" data-love-dot="1" aria-label="Show review 2"></button>
            <button type="button" class="mh-dots__dot" data-love-dot="2" aria-label="Show review 3"></button>
          {%- endif -%}
        </div>
      </div>

      <div class="dh-reviews home-desktop">
        <h2 class="dh-heading dh-heading--light">{{ review_heading_d }}</h2>
        <div class="dh-reviews__grid">
          {%- if review_blocks.size > 0 -%}
            {%- for block in review_blocks -%}
              <blockquote {{ block.shopify_attributes }}>
                <div class="dh-reviews__stars">★★★★★</div>
                <p>{{ block.settings.quote }}</p>
                <footer>
                  {%- if block.settings.avatar != blank -%}
                    <img src="{{ block.settings.avatar | image_url: width: 72 }}" alt="" loading="lazy">
                  {%- else -%}
                    <img src="{{ 'logo-purani-rasoi.png' | asset_url }}" alt="" loading="lazy">
                  {%- endif -%}
                  <cite>{{ block.settings.author }}</cite>
                </footer>
              </blockquote>
            {%- endfor -%}
          {%- else -%}
            <blockquote>
              <div class="dh-reviews__stars">★★★★★</div>
              <p>“Aam ka achar bilkul ghar jaisa swad. Quality aur packaging dono hi best!”</p>
              <footer>
                <img src="{{ 'logo-purani-rasoi.png' | asset_url }}" alt="" loading="lazy">
                <cite>Priya Sharma</cite>
              </footer>
            </blockquote>
            <blockquote>
              <div class="dh-reviews__stars">★★★★★</div>
              <p>“Nimbu ka achar try kiya, bahut hi tasty aur fresh. Will order again!”</p>
              <footer>
                <img src="{{ 'logo-purani-rasoi.png' | asset_url }}" alt="" loading="lazy">
                <cite>Rohit Verma</cite>
              </footer>
            </blockquote>
            <blockquote>
              <div class="dh-reviews__stars">★★★★★</div>
              <p>“Best achar I have ever had. 100% recommended!”</p>
              <footer>
                <img src="{{ 'logo-purani-rasoi.png' | asset_url }}" alt="" loading="lazy">
                <cite>Neha Agarwal</cite>
              </footer>
            </blockquote>
          {%- endif -%}
        </div>
      </div>
    </section>

    {%- if section.settings.show_promo -%}
      <section class="pdp-promo" data-pdp-promo data-end="{{ section.settings.promo_end }}">
        <div class="pdp-promo__copy">
          <span class="pdp-promo__gift material-symbols-outlined" aria-hidden="true">redeem</span>
          <div>
            <h2>{{ promo_heading }}</h2>
            {%- if section.settings.promo_subtext != blank -%}
              <p>{{ section.settings.promo_subtext }}</p>
            {%- endif -%}
          </div>
        </div>
        <div class="pdp-promo__timer" aria-label="Offer ends in">
          <div class="pdp-promo__unit"><strong data-promo-h>00</strong><span>Hrs</span></div>
          <span class="pdp-promo__sep">:</span>
          <div class="pdp-promo__unit"><strong data-promo-m>00</strong><span>Mins</span></div>
          <span class="pdp-promo__sep">:</span>
          <div class="pdp-promo__unit"><strong data-promo-s>00</strong><span>Secs</span></div>
        </div>
      </section>
    {%- endif -%}

    {%- if section.settings.show_related -%}
      <div class="pdp-related">
        <h2>{{ section.settings.related_heading }}</h2>
        <div class="pdp-related__rail hide-scrollbar">
          {%- assign related = product.collections.first -%}
          {%- if related == blank -%}
            {%- assign related = collections.all -%}
          {%- endif -%}
          {%- if related -%}
            {%- for rel in related.products limit: 8 -%}
              {%- unless rel.id == product.id -%}
                {% render 'product-card', product: rel %}
              {%- endunless -%}
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    {%- assign acc_count = 0 -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'accordion' -%}{%- assign acc_count = acc_count | plus: 1 -%}{%- endif -%}
    {%- endfor -%}
    {%- if acc_count > 0 -%}
      <div class="pdp-acc">
        {%- for block in section.blocks -%}
          {%- if block.type == 'accordion' -%}
            <details {% if block.settings.open %}open{% endif %} {{ block.shopify_attributes }}>
              <summary>
                <span>{{ block.settings.title }}</span>
                <span class="pdp-acc__chev material-symbols-outlined" aria-hidden="true">expand_more</span>
              </summary>
              <div class="pdp-acc__body">{{ block.settings.body }}</div>
            </details>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

<script type="application/json" id="ProductJSON-{{ section.id }}">
  {{ product | json }}
</script>
<script>
  (function () {
    const root = document.querySelector('[data-pdp][data-section-id="{{ section.id }}"]');
    const form = document.getElementById('{{ product_form_id }}');
    if (!root || !form) return;

    const product = JSON.parse(document.getElementById('ProductJSON-{{ section.id }}').textContent);
    const idInput = form.querySelector('[data-variant-id]');
    const selects = form.querySelectorAll('select[data-option-position]');
    const qtySpan = form.querySelector('[data-qty-value]');
    const qtyInput = form.querySelector('[data-qty-input]');
    const buyNow = form.querySelector('[data-buy-now]');
    const addBtn = form.querySelector('[data-add-to-cart]');
    const mainImg = document.getElementById('pdp-main-img');
    const stockEl = root.querySelector('[data-pdp-stock]');

    function syncQty() {
      if (qtySpan && qtyInput) qtySpan.textContent = qtyInput.value;
    }
    form.querySelector('[data-qty-minus]')?.addEventListener('click', () => {
      qtyInput.value = Math.max(1, (parseInt(qtyInput.value, 10) || 1) - 1);
      syncQty();
    });
    form.querySelector('[data-qty-plus]')?.addEventListener('click', () => {
      qtyInput.value = (parseInt(qtyInput.value, 10) || 1) + 1;
      syncQty();
    });

    function addThen(url) {
      const fd = new FormData(form);
      return fetch('/cart/add.js', {
        method: 'POST',
        body: fd,
        headers: { Accept: 'application/json' },
      }).then(async (r) => {
        if (!r.ok) throw new Error('add failed');
        if (url) {
          window.location.href = url;
          return;
        }
        const cart = await fetch('/cart.js').then((res) => res.json());
        window.PuraniRasoi?.updateCartUI?.(cart);
      });
    }

    buyNow?.addEventListener('click', (e) => {
      e.preventDefault();
      addThen('/checkout').catch(() => form.submit());
    });

    root.querySelectorAll('[data-thumb]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const src = btn.getAttribute('data-thumb');
        if (mainImg && src) mainImg.src = src;
        root.querySelectorAll('[data-thumb]').forEach((b) => b.classList.toggle('is-active', b === btn));
      });
    });

    form.querySelectorAll('[data-option-value]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const pos = btn.getAttribute('data-option-position');
        const val = btn.getAttribute('data-option-value');
        const select = form.querySelector('select[data-option-position="' + pos + '"]');
        if (!select) return;
        select.value = val;
        form.querySelectorAll('[data-option-position="' + pos + '"][data-option-value]').forEach((b) => {
          b.classList.toggle('is-active', b === btn);
        });
        select.dispatchEvent(new Event('change', { bubbles: true }));
      });
    });

    function selectedOptions() {
      return Array.from(selects).map((s) => s.value);
    }
    function findVariant() {
      const opts = selectedOptions();
      return product.variants.find((v) => v.options.every((o, i) => o === opts[i]));
    }
    function money(cents) {
      if (window.Shopify && Shopify.formatMoney) {
        try {
          return Shopify.formatMoney(cents, {{ shop.money_format | json }});
        } catch (e) {}
      }
      return '₹' + (cents / 100).toFixed(0);
    }
    function update() {
      const v = findVariant() || product.variants[0];
      if (!v || !idInput) return;
      idInput.value = v.id;
      const priceEl = document.getElementById('price-{{ section.id }}');
      if (priceEl) {
        let row = '<div class="pdp-price__row"><strong data-price-current">' + money(v.price) + '</strong>';
        if (v.compare_at_price > v.price) {
          const save = Math.round(((v.compare_at_price - v.price) * 100) / v.compare_at_price);
          row += ' <s data-price-compare>' + money(v.compare_at_price) + '</s> <span class="pdp-price__off" data-price-off>' + save + '% OFF</span>';
        }
        row += '</div><p class="pdp-price__tax">(Inclusive of all taxes)</p>';
        priceEl.innerHTML = row;
      }
      if (addBtn) {
        addBtn.disabled = !v.available;
        addBtn.innerHTML = v.available
          ? '<span class="material-symbols-outlined" aria-hidden="true">shopping_cart</span> ADD TO CART'
          : {{ 'products.product.sold_out' | t | json }};
      }
      if (buyNow) buyNow.disabled = !v.available;
      if (stockEl) {
        if (v.available) {
          stockEl.classList.remove('pdp-stock--out');
          stockEl.innerHTML = '<span class="material-symbols-outlined" aria-hidden="true">check_circle</span> In Stock';
        } else {
          stockEl.classList.add('pdp-stock--out');
          stockEl.textContent = 'Sold out';
        }
      }
      if (v.featured_image && mainImg) {
        mainImg.src = v.featured_image.src.replace(/(\.[a-zA-Z]+)(\?.*)?$/, '_1400x$1');
      }
    }
    selects.forEach((s) => s.addEventListener('change', update));

    /* Promo countdown */
    const promo = root.querySelector('[data-pdp-promo]');
    if (promo) {
      const endRaw = promo.getAttribute('data-end');
      const end = endRaw ? new Date(endRaw).getTime() : 0;
      const hEl = promo.querySelector('[data-promo-h]');
      const mEl = promo.querySelector('[data-promo-m]');
      const sEl = promo.querySelector('[data-promo-s]');
      function tick() {
        if (!end) return;
        const diff = Math.max(0, end - Date.now());
        const h = Math.floor(diff / 3600000);
        const m = Math.floor((diff % 3600000) / 60000);
        const s = Math.floor((diff % 60000) / 1000);
        if (hEl) hEl.textContent = String(h).padStart(2, '0');
        if (mEl) mEl.textContent = String(m).padStart(2, '0');
        if (sEl) sEl.textContent = String(s).padStart(2, '0');
      }
      tick();
      setInterval(tick, 1000);
    }
  })();
</script>

