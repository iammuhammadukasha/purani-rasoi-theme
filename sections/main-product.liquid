{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_form_id = 'product-form-' | append: section.id
  assign short_desc = section.settings.short_description
  if short_desc == blank
    assign short_desc = product.description | strip_html | truncatewords: 28
  endif
-%}

<div class="pdp max-w-site mx-auto">
  <div class="pdp-layout">
    <section class="pdp-gallery" aria-label="Product images">
      <div class="pdp-gallery__main">
        {%- if product.selected_or_first_available_variant.featured_media != blank -%}
          {%- assign featured = product.selected_or_first_available_variant.featured_media -%}
        {%- else -%}
          {%- assign featured = product.featured_media -%}
        {%- endif -%}
        {%- if featured -%}
          <img
            id="pdp-main-img"
            src="{{ featured | image_url: width: 1200 }}"
            alt="{{ featured.alt | escape | default: product.title | escape }}"
            width="800"
            height="800"
          >
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'pdp-placeholder' }}
        {%- endif -%}
        <button type="button" class="pdp-wish" aria-label="Add to wishlist" data-wishlist>
          <span class="material-symbols-outlined" aria-hidden="true">favorite</span>
        </button>
      </div>

      {%- if product.media.size > 1 -%}
        <div class="pdp-thumbs-wrap">
          <button type="button" class="pdp-thumbs__nav" data-thumbs-prev aria-label="Previous images">‹</button>
          <div class="pdp-thumbs" role="list" data-thumbs-rail>
            {%- for media in product.media -%}
              <button
                type="button"
                class="pdp-thumbs__item{% if forloop.first %} is-active{% endif %}"
                data-thumb="{{ media | image_url: width: 1200 }}"
                aria-label="View image {{ forloop.index }}"
              >
                <img src="{{ media | image_url: width: 200 }}" alt="" loading="lazy" width="80" height="80">
              </button>
            {%- endfor -%}
          </div>
          <button type="button" class="pdp-thumbs__nav" data-thumbs-next aria-label="Next images">›</button>
        </div>
      {%- endif -%}
    </section>

    <section class="pdp-body">
      <h1 class="pdp-title">{{ product.title }}</h1>

      <div class="pdp-meta">
        <div class="pdp-meta__rating">
          <span class="pdp-meta__stars" aria-hidden="true">★★★★★</span>
          <span class="pdp-meta__count">({{ section.settings.review_count }} Reviews)</span>
        </div>
        {%- if product.available -%}
          <span class="pdp-stock">In Stock</span>
        {%- else -%}
          <span class="pdp-stock pdp-stock--out">Sold out</span>
        {%- endif -%}
      </div>

      {%- if short_desc != blank -%}
        <p class="pdp-desc">{{ short_desc }}</p>
      {%- endif -%}

      {% form 'product', product, id: product_form_id, class: 'product-form', data-product-form: '' %}
        <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id>

        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <span class="pdp-label">{{ option.name }}</span>
            <div class="pdp-weights" role="group" aria-label="{{ option.name }}">
              {%- for value in option.values -%}
                <button
                  type="button"
                  data-option-value="{{ value | escape }}"
                  data-option-name="{{ option.name | escape }}"
                  data-option-position="{{ option.position }}"
                  {% if option.selected_value == value %}class="is-active"{% endif %}
                >{{ value }}</button>
              {%- endfor -%}
            </div>
            <select
              id="Option-{{ section.id }}-{{ forloop.index0 }}"
              name="options[{{ option.name | escape }}]"
              data-option-position="{{ option.position }}"
              class="sr-only"
            >
              {%- for value in option.values -%}
                <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>{{ value }}</option>
              {%- endfor -%}
            </select>
          {%- endfor -%}
        {%- endunless -%}

        <div class="pdp-price" id="price-{{ section.id }}">
          <div class="pdp-price__row">
            <strong>{{ current_variant.price | money }}</strong>
            {%- if current_variant.compare_at_price > current_variant.price -%}
              <s>{{ current_variant.compare_at_price | money }}</s>
              {%- assign save = current_variant.compare_at_price | minus: current_variant.price | times: 100.0 | divided_by: current_variant.compare_at_price | round -%}
              <span>{{ save }}% OFF</span>
            {%- endif -%}
          </div>
          <p class="pdp-price__tax">(Inclusive of all taxes)</p>
        </div>

        <div class="pdp-actions">
          <div class="pdp-qty" aria-label="{{ 'products.product.quantity' | t }}">
            <button type="button" id="qty-minus" aria-label="Decrease quantity">−</button>
            <input
              id="Quantity-product"
              type="number"
              name="quantity"
              value="1"
              min="1"
              class="sr-only"
            >
            <span id="qty-value">1</span>
            <button type="button" id="qty-plus" aria-label="Increase quantity">+</button>
          </div>
          <button
            type="submit"
            class="pdp-add"
            name="add"
            {% unless current_variant.available %}disabled{% endunless %}
          >
            <span class="material-symbols-outlined" aria-hidden="true">shopping_cart</span>
            {%- if current_variant.available -%}
              ADD TO CART
            {%- else -%}
              {{ 'products.product.sold_out' | t }}
            {%- endif -%}
          </button>
        </div>

        <button
          type="submit"
          class="pdp-buy"
          name="add"
          data-buy-now
          {% unless current_variant.available %}disabled{% endunless %}
        >
          BUY NOW
        </button>
      {% endform %}

      <div class="pdp-trust">
        {%- for block in section.blocks -%}
          {%- if block.type == 'trust' -%}
            <div class="pdp-trust__item" {{ block.shopify_attributes }}>
              <span class="material-symbols-outlined" aria-hidden="true">{{ block.settings.icon }}</span>
              <span>{{ block.settings.label }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="pdp-acc">
        {%- for block in section.blocks -%}
          {%- if block.type == 'accordion' -%}
            <details {% if block.settings.open %}open{% endif %} {{ block.shopify_attributes }}>
              <summary>{{ block.settings.title }} <span aria-hidden="true">▾</span></summary>
              <div class="pdp-acc__body">{{ block.settings.body }}</div>
            </details>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if section.settings.show_related -%}
        <div class="pdp-related">
          <h2>{{ section.settings.related_heading }}</h2>
          <div class="pdp-related__rail hide-scrollbar">
            {%- assign related = product.collections.first -%}
            {%- if related -%}
              {%- for rel in related.products limit: 6 -%}
                {%- unless rel.id == product.id -%}
                  {% render 'product-card', product: rel %}
                {%- endunless -%}
              {%- endfor -%}
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    </section>
  </div>
</div>

<script type="application/json" id="ProductJSON-{{ section.id }}">
  {{ product | json }}
</script>
<script>
  (function () {
    const product = JSON.parse(document.getElementById('ProductJSON-{{ section.id }}').textContent);
    const form = document.getElementById('{{ product_form_id }}');
    if (!form) return;
    const idInput = form.querySelector('[data-variant-id]');
    const selects = form.querySelectorAll('select[data-option-position]');
    const qtySpan = document.getElementById('qty-value');
    const qtyInput = document.getElementById('Quantity-product');
    const buyNow = form.querySelector('[data-buy-now]');

    function syncQty() {
      if (qtySpan && qtyInput) qtySpan.textContent = qtyInput.value;
    }
    document.getElementById('qty-minus')?.addEventListener('click', () => {
      qtyInput.value = Math.max(1, (parseInt(qtyInput.value, 10) || 1) - 1);
      syncQty();
    });
    document.getElementById('qty-plus')?.addEventListener('click', () => {
      qtyInput.value = (parseInt(qtyInput.value, 10) || 1) + 1;
      syncQty();
    });

    buyNow?.addEventListener('click', (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      fetch('/cart/add.js', {
        method: 'POST',
        body: fd,
        headers: { Accept: 'application/json' },
      })
        .then((r) => {
          if (!r.ok) throw new Error('add failed');
          window.location.href = '/checkout';
        })
        .catch(() => {
          form.submit();
        });
    });

    function selectedOptions() {
      return Array.from(selects).map((s) => s.value);
    }
    function findVariant() {
      const opts = selectedOptions();
      return product.variants.find((v) => v.options.every((o, i) => o === opts[i]));
    }
    function money(cents) {
      if (window.Shopify && Shopify.formatMoney) return Shopify.formatMoney(cents);
      return '₹' + (cents / 100).toFixed(0);
    }
    function update() {
      const v = findVariant();
      if (!v || !idInput) return;
      idInput.value = v.id;
      const priceEl = document.getElementById('price-{{ section.id }}');
      if (priceEl) {
        let row = '<div class="pdp-price__row"><strong>' + money(v.price) + '</strong>';
        if (v.compare_at_price > v.price) {
          const save = Math.round(((v.compare_at_price - v.price) * 100) / v.compare_at_price);
          row += ' <s>' + money(v.compare_at_price) + '</s> <span>' + save + '% OFF</span>';
        }
        row += '</div><p class="pdp-price__tax">(Inclusive of all taxes)</p>';
        priceEl.innerHTML = row;
      }
      const submit = form.querySelector('.pdp-add');
      if (submit) {
        submit.disabled = !v.available;
        submit.innerHTML = v.available
          ? '<span class="material-symbols-outlined" aria-hidden="true">shopping_cart</span> ADD TO CART'
          : {{ 'products.product.sold_out' | t | json }};
      }
      if (buyNow) buyNow.disabled = !v.available;
      const stock = document.querySelector('.pdp-stock');
      if (stock) {
        stock.textContent = v.available ? 'In Stock' : 'Sold out';
        stock.classList.toggle('pdp-stock--out', !v.available);
      }
    }
    selects.forEach((s) => s.addEventListener('change', update));

    const rail = document.querySelector('[data-thumbs-rail]');
    document.querySelector('[data-thumbs-prev]')?.addEventListener('click', () => {
      rail?.scrollBy({ left: -120, behavior: 'smooth' });
    });
    document.querySelector('[data-thumbs-next]')?.addEventListener('click', () => {
      rail?.scrollBy({ left: 120, behavior: 'smooth' });
    });
  })();
</script>

{% schema %}
{
  "name": "Product information",
  "settings": [
    { "type": "textarea", "id": "short_description", "label": "Short description (optional)", "info": "Shown under rating. Falls back to truncated product description." },
    { "type": "text", "id": "review_count", "label": "Review count label", "default": "125" },
    { "type": "checkbox", "id": "show_related", "label": "Show related products", "default": true },
    { "type": "text", "id": "related_heading", "label": "Related heading", "default": "You May Also Like" }
  ],
  "blocks": [
    {
      "type": "trust",
      "name": "Trust badge",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon", "default": "local_shipping" },
        { "type": "text", "id": "label", "label": "Label", "default": "Free Shipping" }
      ]
    },
    {
      "type": "accordion",
      "name": "Accordion row",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Product Highlights" },
        { "type": "richtext", "id": "body", "label": "Body", "default": "<ul><li>100% Homemade</li><li>No Artificial Colors</li><li>Made in Small Batches</li></ul>" },
        { "type": "checkbox", "id": "open", "label": "Open by default", "default": false }
      ]
    }
  ],
  "presets": [{ "name": "Product information" }]
}
{% endschema %}
