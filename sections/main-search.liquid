{%- liquid
  assign heading = section.settings.heading | default: 'Search'
  assign crumb = section.settings.crumb_label | default: 'Search'
  assign search_terms = search.terms | default: ''
  assign results_count = search.results_count | default: 0
-%}

<section class="shop-banner search-banner" aria-label="{{ heading | escape }}">
  {%- if section.settings.banner != blank -%}
    <img src="{{ section.settings.banner | image_url: width: 2000 }}" alt="" loading="eager">
  {%- else -%}
    <img src="{{ 'hero-banner.png' | asset_url }}" alt="" loading="eager">
  {%- endif -%}
  <div class="shop-banner__shade" aria-hidden="true"></div>
  <div class="shop-banner__content">
    <h1>{{ heading }}</h1>
    <p class="shop-banner__crumbs">
      <a href="{{ routes.root_url }}">Home</a> &gt; {{ crumb }}
    </p>
  </div>
</section>

{%- if section.settings.show_trust -%}
  <section class="shop-usp" aria-label="Brand promises">
    {%- for block in section.blocks -%}
      {%- if block.type == 'trust' -%}
        <div class="shop-usp__item" {{ block.shopify_attributes }}>
          <span class="shop-usp__icon material-symbols-outlined" aria-hidden="true">{{ block.settings.icon }}</span>
          <span>{{ block.settings.label }}</span>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </section>
{%- endif -%}

<section class="search-panel" aria-label="{{ 'general.search' | t }}">
  <form class="search-panel__form" action="{{ routes.search_url }}" method="get" role="search">
    <label class="sr-only" for="SearchInput">{{ 'general.search' | t }}</label>
    <div class="search-panel__field">
      <span class="material-symbols-outlined search-panel__icon" aria-hidden="true">search</span>
      <input
        id="SearchInput"
        type="search"
        name="q"
        value="{{ search_terms | escape }}"
        placeholder="{{ section.settings.placeholder | default: 'Search for pickles, achar…' | escape }}"
        autocomplete="off"
      >
      <input type="hidden" name="type" value="product">
      <button type="submit" class="search-panel__submit">
        {{ 'general.search' | t }}
      </button>
    </div>
  </form>

  {%- if search.performed -%}
    <p class="search-panel__meta">
      {%- if results_count == 0 -%}
        No results for “{{ search_terms | escape }}”
      {%- elsif results_count == 1 -%}
        1 result for “{{ search_terms | escape }}”
      {%- else -%}
        {{ results_count }} results for “{{ search_terms | escape }}”
      {%- endif -%}
    </p>
  {%- else -%}
    <p class="search-panel__meta">{{ section.settings.intro | default: 'Find your favourite homemade pickles and pantry staples.' }}</p>
  {%- endif -%}
</section>

<section class="shop-grid search-grid" aria-label="Search results" id="search-results">
  {%- if search.performed -%}
    {%- paginate search.results by section.settings.products_per_page -%}
      {%- assign product_hits = 0 -%}
      {%- for item in search.results -%}
        {%- if item.object_type == 'product' -%}
          {%- assign product_hits = product_hits | plus: 1 -%}
          {% render 'product-card', product: item, show_rating: true %}
        {%- endif -%}
      {%- endfor -%}

      {%- if product_hits == 0 -%}
        <div class="search-empty">
          <span class="material-symbols-outlined" aria-hidden="true">search_off</span>
          <h2>No products found</h2>
          <p>Try a different spelling, or browse the full shop.</p>
          <a class="pr-btn pr-btn--primary" href="{{ routes.all_products_collection_url }}">Browse Shop</a>
        </div>
      {%- endif -%}

      {%- if paginate.pages > 1 -%}
        <nav class="pagination search-pagination" aria-label="Search pagination">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}">← Prev</a>
          {%- endif -%}
          <span>Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}">Next →</a>
          {%- endif -%}
        </nav>
      {%- endif -%}
    {%- endpaginate -%}
  {%- else -%}
    <div class="search-empty search-empty--idle">
      <span class="material-symbols-outlined" aria-hidden="true">grocery</span>
      <h2>What are you craving?</h2>
      <p>Search by pickle name, flavour, or size — or explore bestsellers.</p>
      <a class="pr-btn pr-btn--secondary" href="{{ routes.all_products_collection_url }}">View All Products →</a>
    </div>
  {%- endif -%}
</section>

{%- if section.settings.show_promise -%}
  {%- assign promise_count = 0 -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'promise' -%}
      {%- assign promise_count = promise_count | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}
  <section class="shop-promise" aria-label="Our promises">
    <div class="shop-promise__inner">
      {%- if promise_count > 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'promise' -%}
            <div class="shop-promise__item" {{ block.shopify_attributes }}>
              <span class="shop-promise__icon material-symbols-outlined" aria-hidden="true">{{ block.settings.icon }}</span>
              <span>{{ block.settings.label }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        <div class="shop-promise__item">
          <span class="shop-promise__icon material-symbols-outlined" aria-hidden="true">emoji_people</span>
          <span>Made with Tradition</span>
        </div>
        <div class="shop-promise__item">
          <span class="shop-promise__icon material-symbols-outlined" aria-hidden="true">wb_sunny</span>
          <span>Sun Dried &amp; Natural</span>
        </div>
        <div class="shop-promise__item">
          <span class="shop-promise__icon material-symbols-outlined" aria-hidden="true">spa</span>
          <span>Premium Ingredients</span>
        </div>
        <div class="shop-promise__item">
          <span class="shop-promise__icon material-symbols-outlined" aria-hidden="true">verified_user</span>
          <span>Hygienically Packed</span>
        </div>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Search results",
  "settings": [
    { "type": "text", "id": "heading", "label": "Banner heading", "default": "Search" },
    { "type": "text", "id": "crumb_label", "label": "Breadcrumb label", "default": "Search" },
    { "type": "image_picker", "id": "banner", "label": "Banner image" },
    { "type": "text", "id": "placeholder", "label": "Search placeholder", "default": "Search for pickles, achar…" },
    { "type": "text", "id": "intro", "label": "Intro text (before search)", "default": "Find your favourite homemade pickles and pantry staples." },
    { "type": "checkbox", "id": "show_trust", "label": "Show trust badges under hero", "default": true },
    { "type": "checkbox", "id": "show_promise", "label": "Show promise strip above footer", "default": true },
    { "type": "range", "id": "products_per_page", "min": 8, "max": 36, "step": 4, "label": "Results per page", "default": 16 }
  ],
  "blocks": [
    {
      "type": "trust",
      "name": "Trust badge",
      "settings": [
        { "type": "text", "id": "icon", "label": "Material icon name", "default": "soup_kitchen" },
        { "type": "html", "id": "label", "label": "Label (use <br> for line break)", "default": "100%<br>Homemade" }
      ]
    },
    {
      "type": "promise",
      "name": "Promise item",
      "settings": [
        { "type": "text", "id": "icon", "label": "Material icon name", "default": "wb_sunny" },
        { "type": "text", "id": "label", "label": "Label", "default": "Sun Dried & Natural" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Search results"
    }
  ]
}
{% endschema %}
