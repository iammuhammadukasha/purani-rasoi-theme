{%- liquid
  if section.settings.hero_image != blank
    assign hero_img = section.settings.hero_image | image_url: width: 1800
  else
    assign hero_fallback = section.settings.hero_fallback | default: 'story-kitchen.png'
    assign hero_img = hero_fallback | asset_url
  endif
-%}

<section id="pickle-process" class="pr-process" aria-labelledby="ProcessHeading-{{ section.id }}">
  <div class="pr-process__inner">
    <header class="pr-process__head">
      <h2 id="ProcessHeading-{{ section.id }}" class="pr-process__title">
        <span class="pr-process__flourish" aria-hidden="true">
          <img src="{{ 'cats-flourish-leaf.png' | asset_url }}" alt="" width="84" height="36" loading="lazy">
        </span>
        <span class="pr-process__heading-text">{{ section.settings.heading | default: 'Our Pickle Making Process' }}</span>
        <span class="pr-process__flourish pr-process__flourish--flip" aria-hidden="true">
          <img src="{{ 'cats-flourish-leaf.png' | asset_url }}" alt="" width="84" height="36" loading="lazy">
        </span>
      </h2>
    </header>

    <div class="pr-process__flow">
      <div class="pr-process__hero">
        <img
          src="{{ hero_img }}"
          alt="{{ section.settings.hero_alt | default: 'Traditional pickle making' | escape }}"
          width="1600"
          height="900"
          loading="lazy"
        >
      </div>

      <ol class="pr-process__steps">
        {%- assign step_i = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'step' -%}
            {%- assign step_i = step_i | plus: 1 -%}
            {%- liquid
              if block.settings.image != blank
                assign step_img = block.settings.image | image_url: width: 480
              else
                assign step_fallback = block.settings.fallback_asset | default: 'story-kitchen.png'
                assign step_img = step_fallback | asset_url
              endif
              assign sketch = block.settings.sketch | default: 'mango'
            -%}
            <li class="pr-process__step" {{ block.shopify_attributes }}>
              <div class="pr-process__marker" aria-hidden="true">
                <span class="pr-process__num">{{ step_i }}</span>
                <span class="pr-process__leaf">
                  <img src="{{ 'cats-flourish-leaf.png' | asset_url }}" alt="" width="28" height="16" loading="lazy">
                </span>
              </div>
              <article class="pr-process__card">
                <div class="pr-process__card-media">
                  <img src="{{ step_img }}" alt="" width="200" height="160" loading="lazy">
                </div>
                <h3 class="pr-process__card-title">{{ block.settings.title }}</h3>
                <div class="pr-process__sketch" aria-hidden="true">
                  {%- case sketch -%}
                    {%- when 'spices' -%}
                      <svg viewBox="0 0 64 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <ellipse cx="22" cy="34" rx="12" ry="6" stroke="#8b7355" stroke-width="1.4"/>
                        <path d="M14 34c2-10 6-18 10-22" stroke="#8b7355" stroke-width="1.3" stroke-linecap="round"/>
                        <ellipse cx="44" cy="30" rx="9" ry="5" stroke="#8b7355" stroke-width="1.4"/>
                        <circle cx="40" cy="18" r="2" fill="#8b7355" opacity="0.5"/>
                        <circle cx="48" cy="14" r="1.5" fill="#8b7355" opacity="0.45"/>
                        <circle cx="52" cy="20" r="1.8" fill="#8b7355" opacity="0.4"/>
                      </svg>
                    {%- when 'mix' -%}
                      <svg viewBox="0 0 64 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <ellipse cx="32" cy="36" rx="18" ry="7" stroke="#8b7355" stroke-width="1.4"/>
                        <path d="M16 34c2-12 10-20 16-22 6 2 14 10 16 22" stroke="#8b7355" stroke-width="1.4"/>
                        <path d="M28 18l14-10" stroke="#8b7355" stroke-width="1.4" stroke-linecap="round"/>
                        <circle cx="44" cy="6" r="2.2" stroke="#8b7355" stroke-width="1.2"/>
                      </svg>
                    {%- when 'jar' -%}
                      <svg viewBox="0 0 64 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="20" y="10" width="24" height="6" rx="1.5" stroke="#8b7355" stroke-width="1.4"/>
                        <path d="M22 16h20v22c0 3-4 5-10 5s-10-2-10-5V16z" stroke="#8b7355" stroke-width="1.4"/>
                        <path d="M26 24h12M26 30h10" stroke="#8b7355" stroke-width="1.1" stroke-linecap="round" opacity="0.6"/>
                      </svg>
                    {%- when 'pack' -%}
                      <svg viewBox="0 0 64 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="22" y="8" width="20" height="5" rx="1" stroke="#8b7355" stroke-width="1.3"/>
                        <path d="M24 13h16v26a2 2 0 01-2 2H26a2 2 0 01-2-2V13z" stroke="#8b7355" stroke-width="1.4"/>
                        <circle cx="32" cy="26" r="5" stroke="#8b7355" stroke-width="1.2"/>
                        <path d="M42 34c4 0 8 2 10 5" stroke="#8b7355" stroke-width="1.2" stroke-linecap="round"/>
                      </svg>
                    {%- else -%}
                      <svg viewBox="0 0 64 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M18 36c2-14 10-24 18-28 4 6 10 16 12 28" stroke="#8b7355" stroke-width="1.4" stroke-linecap="round"/>
                        <path d="M28 14c4 2 8 8 10 14" stroke="#8b7355" stroke-width="1.2" stroke-linecap="round" opacity="0.7"/>
                        <ellipse cx="22" cy="34" rx="5" ry="3" stroke="#8b7355" stroke-width="1.2"/>
                        <ellipse cx="40" cy="36" rx="6" ry="3.5" stroke="#8b7355" stroke-width="1.2"/>
                      </svg>
                  {%- endcase -%}
                </div>
              </article>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ol>
    </div>

    {%- assign feature_blocks = section.blocks | where: 'type', 'feature' -%}
    {%- if feature_blocks.size > 0 -%}
      <div class="pr-process__features">
        <div class="pr-process__features-leaf pr-process__features-leaf--left" aria-hidden="true">
          <img src="{{ 'cats-flourish-leaf.png' | asset_url }}" alt="" width="84" height="36" loading="lazy">
        </div>
        <div class="pr-process__features-row">
          {%- for block in feature_blocks -%}
            <div class="pr-process__feature" {{ block.shopify_attributes }}>
              <span class="pr-process__feature-icon material-symbols-outlined" aria-hidden="true">{{ block.settings.icon | default: 'home' }}</span>
              <span class="pr-process__feature-label">{{ block.settings.title }}</span>
            </div>
          {%- endfor -%}
        </div>
        <div class="pr-process__features-leaf pr-process__features-leaf--right" aria-hidden="true">
          <img src="{{ 'cats-flourish-leaf.png' | asset_url }}" alt="" width="84" height="36" loading="lazy">
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Pickle making process",
  "tag": "section",
  "class": "pr-process-section",
  "settings": [
    { "type": "image_picker", "id": "hero_image", "label": "Hero image" },
    { "type": "text", "id": "hero_fallback", "label": "Hero fallback asset", "default": "story-kitchen.png" },
    { "type": "text", "id": "hero_alt", "label": "Hero alt text", "default": "Traditional pickle making" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our Pickle Making Process" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Process step",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Carefully Selected Ingredients" },
        { "type": "image_picker", "id": "image", "label": "Step image" },
        { "type": "text", "id": "fallback_asset", "label": "Fallback asset filename", "default": "story-kitchen.png" },
        {
          "type": "select",
          "id": "sketch",
          "label": "Sketch style",
          "options": [
            { "value": "mango", "label": "Mango / ingredients" },
            { "value": "spices", "label": "Spices" },
            { "value": "mix", "label": "Mixing bowl" },
            { "value": "jar", "label": "Aging jar" },
            { "value": "pack", "label": "Packed jar" }
          ],
          "default": "mango"
        }
      ]
    },
    {
      "type": "feature",
      "name": "Bottom feature",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "icon", "label": "Material icon name", "default": "home" },
        { "type": "text", "id": "title", "label": "Label", "default": "Homemade Taste" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pickle making process",
      "blocks": [
        { "type": "step", "settings": { "title": "Carefully Selected Ingredients", "fallback_asset": "aam.png", "sketch": "mango" } },
        { "type": "step", "settings": { "title": "Blended With Authentic Spices", "fallback_asset": "benefit-preservatives.png", "sketch": "spices" } },
        { "type": "step", "settings": { "title": "Handmixed With Care", "fallback_asset": "banner-kitchen.png", "sketch": "mix" } },
        { "type": "step", "settings": { "title": "Naturally Aged To Perfection", "fallback_asset": "benefit-batches.png", "sketch": "jar" } },
        { "type": "step", "settings": { "title": "Packed Hygienically With Love", "fallback_asset": "product-aam.png", "sketch": "pack" } },
        { "type": "feature", "settings": { "icon": "home", "title": "Homemade Taste" } },
        { "type": "feature", "settings": { "icon": "eco", "title": "No Artificial Preservatives" } },
        { "type": "feature", "settings": { "icon": "soup_kitchen", "title": "Traditional Recipes" } },
        { "type": "feature", "settings": { "icon": "favorite", "title": "Small Batch Made" } }
      ]
    }
  ]
}
{% endschema %}
