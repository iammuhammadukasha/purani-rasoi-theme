{%- liquid
  if section.settings.image != blank
    assign img = section.settings.image | image_url: width: 2000
  else
    assign img = 'hero-banner.png' | asset_url
  endif
  assign line1 = section.settings.heading_line1 | default: 'Har Bite Mein'
  assign line2 = section.settings.heading_line2 | default: 'Ghar Ka Asli Swad'
  assign copy = section.settings.copy | default: 'Dadi ke haathon ka parampara aur maa ke pyaar ka swaad.'
  assign cta_label = section.settings.cta_label | default: 'Jaaniye Hamari Kahani'
  assign cta_link = section.settings.cta_link | default: '#story'
-%}

<section id="story" class="story-hero" aria-label="{{ cta_label | escape }}">
  <div class="story-hero__media">
    <img
      src="{{ img }}"
      alt="{{ section.settings.image.alt | default: line1 | escape }}"
      width="1600"
      height="900"
      loading="lazy"
    >
  </div>
  <div class="story-hero__shade" aria-hidden="true"></div>
  <div class="story-hero__content">
    <h2 class="story-hero__title">
      <span class="story-hero__title-line">{{ line1 }}</span>
      <span class="story-hero__title-accent">{{ line2 }}</span>
    </h2>
    {%- if copy != blank -%}
      <p class="story-hero__copy">{{ copy }}</p>
    {%- endif -%}
    {%- if cta_label != blank -%}
      <a href="{{ cta_link }}" class="story-hero__cta">
        {{ cta_label }}&nbsp;<span aria-hidden="true">→</span>
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Story banner",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "text", "id": "heading_line1", "label": "Heading line 1 (white)", "default": "Har Bite Mein" },
    { "type": "text", "id": "heading_line2", "label": "Heading line 2 (gold)", "default": "Ghar Ka Asli Swad" },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Supporting copy",
      "default": "Dadi ke haathon ka parampara aur maa ke pyaar ka swaad."
    },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Jaaniye Hamari Kahani" },
    { "type": "url", "id": "cta_link", "label": "Button link" }
  ],
  "presets": [{ "name": "Story banner" }]
}
{% endschema %}
