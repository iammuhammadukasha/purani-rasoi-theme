{%- comment -%}
  On product pages, reviews are rendered inside main-product (directly under Why Choose).
  Skip this standalone section so it does not appear again at the bottom.
{%- endcomment -%}
{%- if template.name == 'product' -%}
  {%- comment -%} intentionally empty {%- endcomment -%}
{%- else -%}
<section class="pr-reviews" aria-labelledby="Reviews-{{ section.id }}">
  <div
    class="mh-section mh-section--soft home-mobile love-carousel"
    data-love-carousel
    data-interval="{{ section.settings.interval | default: 4000 }}"
  >
    {%- assign reviews_heading_id = 'Reviews-' | append: section.id -%}
    {% render 'section-heading', heading: section.settings.heading_mobile, heading_id: reviews_heading_id %}

    <div class="love-carousel__viewport">
      {%- for block in section.blocks -%}
        <blockquote
          class="mh-love love-carousel__slide{% if forloop.first %} is-active{% endif %}"
          data-love-slide
          aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
          {{ block.shopify_attributes }}
        >
          <div class="mh-love__stars" aria-hidden="true">★★★★★</div>
          <p>{{ block.settings.quote }}</p>
          <footer>
            {%- if block.settings.avatar != blank -%}
              <img src="{{ block.settings.avatar | image_url: width: 72 }}" alt="" width="36" height="36" loading="lazy">
            {%- else -%}
              <img src="{{ 'logo-purani-rasoi.png' | asset_url }}" alt="" width="36" height="36" loading="lazy">
            {%- endif -%}
            <cite>{{ block.settings.author }}</cite>
          </footer>
        </blockquote>
      {%- endfor -%}
    </div>

    <div class="mh-dots" data-love-dots role="tablist" aria-label="Testimonials">
      {%- for block in section.blocks -%}
        <button
          type="button"
          class="mh-dots__dot{% if forloop.first %} is-active{% endif %}"
          data-love-dot="{{ forloop.index0 }}"
          aria-label="Show review {{ forloop.index }}"
          {% if forloop.first %}aria-current="true"{% endif %}
        ></button>
      {%- endfor -%}
    </div>
  </div>

  <div class="dh-reviews home-desktop">
    {% render 'section-heading', heading: section.settings.heading, class: 'pr-head--light' %}
    <div class="dh-reviews__grid">
      {%- for block in section.blocks -%}
        <blockquote {{ block.shopify_attributes }}>
          <div class="dh-reviews__stars">★★★★★</div>
          <p>{{ block.settings.quote }}</p>
          <footer>
            {%- if block.settings.avatar != blank -%}
              <img src="{{ block.settings.avatar | image_url: width: 72 }}" alt="" loading="lazy">
            {%- else -%}
              <img src="{{ 'logo-purani-rasoi.png' | asset_url }}" alt="" loading="lazy">
            {%- endif -%}
            <cite>{{ block.settings.author }}</cite>
          </footer>
        </blockquote>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading (desktop)", "default": "What Our Customers Say" },
    { "type": "text", "id": "heading_mobile", "label": "Heading (mobile)", "default": "Customer Love" },
    {
      "type": "range",
      "id": "interval",
      "min": 2500,
      "max": 8000,
      "step": 500,
      "unit": "ms",
      "label": "Auto-rotate speed",
      "default": 4000
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "“Aam ka achar bilkul ghar jaisa swad. Quality aur packaging dono hi best!”" },
        { "type": "text", "id": "author", "label": "Author", "default": "Priya Sharma" },
        { "type": "image_picker", "id": "avatar", "label": "Avatar" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "review", "settings": { "quote": "“Aam ka achar bilkul ghar jaisa swad. Quality aur packaging dono hi best!”", "author": "Priya Sharma" } },
        { "type": "review", "settings": { "quote": "“Nimbu ka achar try kiya, bahut hi tasty aur fresh. Will order again!”", "author": "Rohit Verma" } },
        { "type": "review", "settings": { "quote": "“Best achar I have ever had. 100% recommended!”", "author": "Neha Agarwal" } }
      ]
    }
  ]
}
{% endschema %}
