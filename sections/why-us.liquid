<section class="pr-why" aria-labelledby="WhyHeading-{{ section.id }}">
  <div class="pr-why__inner">
    <header class="pr-why__head">
      <h2 id="WhyHeading-{{ section.id }}" class="pr-why__title">
        <span class="pr-why__flourish" aria-hidden="true">
          <img src="{{ 'cats-flourish-leaf.png' | asset_url }}" alt="" width="84" height="36" loading="lazy">
        </span>
        <span class="pr-why__heading-text">{{ section.settings.heading | default: 'Why Purani Rasoi' }}</span>
        <span class="pr-why__flourish pr-why__flourish--flip" aria-hidden="true">
          <img src="{{ 'cats-flourish-leaf.png' | asset_url }}" alt="" width="84" height="36" loading="lazy">
        </span>
      </h2>
      <div class="pr-why__rule" aria-hidden="true"></div>
    </header>

    <div class="pr-why__grid">
      {%- for block in section.blocks -%}
        {%- liquid
          case forloop.index
            when 1
              assign why_img = 'benefit-homemade.png' | asset_url
            when 2
              assign why_img = 'benefit-preservatives.png' | asset_url
            when 3
              assign why_img = 'benefit-recipes.png' | asset_url
            else
              assign why_img = 'benefit-love.png' | asset_url
          endcase
        -%}
        <article class="pr-why__item" {{ block.shopify_attributes }}>
          <div class="pr-why__circle">
            <img src="{{ why_img }}" alt="" width="200" height="200" loading="lazy">
          </div>
          <span class="pr-why__leaf" aria-hidden="true">
            <svg viewBox="0 0 28 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M4 12c4-1 7-5 8-10 1 5 4 9 8 10" stroke="#c9a227" stroke-width="1.3" stroke-linecap="round"/>
              <ellipse cx="12" cy="6" rx="2.4" ry="4.2" fill="#c9a227" opacity="0.9"/>
              <ellipse cx="18" cy="7" rx="2" ry="3.5" fill="#b8893f" opacity="0.85"/>
            </svg>
          </span>
          <h3 class="pr-why__item-title">{{ block.settings.title }}</h3>
          {%- if block.settings.text != blank -%}
            <p class="pr-why__item-text">{{ block.settings.text }}</p>
          {%- endif -%}
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Why us / Benefits",
  "tag": "section",
  "class": "pr-why-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why Purani Rasoi" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Benefit",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Ghar Jaisa Swaad" },
        { "type": "textarea", "id": "text", "label": "Subtitle", "default": "Wahi pyaar, wahi ghar jaisa swaad." },
        { "type": "image_picker", "id": "image", "label": "Icon image" },
        { "type": "text", "id": "fallback_asset", "label": "Fallback asset filename", "default": "benefit-homemade.png" },
        { "type": "text", "id": "icon", "label": "Legacy icon name (unused)", "default": "home" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why us / Benefits",
      "blocks": [
        { "type": "item", "settings": { "title": "Ghar Jaisa Swaad", "text": "Wahi pyaar, wahi ghar jaisa swaad.", "fallback_asset": "benefit-homemade.png" } },
        { "type": "item", "settings": { "title": "No Preservatives", "text": "Koi artificial cheez nahi, sirf natural ingredients.", "fallback_asset": "benefit-preservatives.png" } },
        { "type": "item", "settings": { "title": "Traditional Recipes", "text": "Purani recipes, nayi pehchaan ke saath.", "fallback_asset": "benefit-recipes.png" } },
        { "type": "item", "settings": { "title": "Small Batch Made", "text": "Choti batches, zyada dhyaan, behtar swaad.", "fallback_asset": "benefit-love.png" } }
      ]
    }
  ]
}
{% endschema %}
