{%- liquid
  assign heading = section.settings.reviews_heading_mobile | default: 'Customer Reviews'
  assign write_url = section.settings.write_review_url
  assign review_form_id = 'ProductReviewForm-' | append: section.id

  assign mo_type = section.settings.review_metaobject_type | default: 'customer_product_review' | strip
  assign review_count = 0
  assign rating_sum = 0
  assign count_5 = 0
  assign count_4 = 0
  assign count_3 = 0
  assign count_2 = 0
  assign count_1 = 0
  assign has_meta_reviews = false

  if shop.metaobjects[mo_type].values != blank
    for entry in shop.metaobjects[mo_type].values
      assign entry_product = entry.product.value
      if entry_product == blank or entry_product.id != product.id
        continue
      endif
      if entry.published.value == false
        continue
      endif
      assign has_meta_reviews = true
      assign review_count = review_count | plus: 1
      assign star = entry.rating.value | default: 5 | plus: 0
      assign rating_sum = rating_sum | plus: star
      case star
        when 5
          assign count_5 = count_5 | plus: 1
        when 4
          assign count_4 = count_4 | plus: 1
        when 3
          assign count_3 = count_3 | plus: 1
        when 2
          assign count_2 = count_2 | plus: 1
        else
          assign count_1 = count_1 | plus: 1
      endcase
    endfor
  endif

  if has_meta_reviews
    assign average = rating_sum | times: 1.0 | divided_by: review_count | round: 1
    assign total_label = review_count | append: ' reviews'
    if review_count == 1
      assign total_label = '1 review'
    endif
  else
    assign average = section.settings.reviews_average | default: '4.7'
    assign total_label = section.settings.reviews_total | default: '1,092 reviews'
    assign count_5 = section.settings.star_5_count | default: 896
    assign count_4 = section.settings.star_4_count | default: 132
    assign count_3 = section.settings.star_3_count | default: 42
    assign count_2 = section.settings.star_2_count | default: 13
    assign count_1 = section.settings.star_1_count | default: 9
  endif

  assign bar_total = count_5 | plus: count_4 | plus: count_3 | plus: count_2 | plus: count_1
  if bar_total == 0
    assign bar_total = 1
  endif
  assign pct_5 = count_5 | times: 100.0 | divided_by: bar_total
  assign pct_4 = count_4 | times: 100.0 | divided_by: bar_total
  assign pct_3 = count_3 | times: 100.0 | divided_by: bar_total
  assign pct_2 = count_2 | times: 100.0 | divided_by: bar_total
  assign pct_1 = count_1 | times: 100.0 | divided_by: bar_total
-%}

<section
  class="pdp-customer-reviews"
  aria-labelledby="Reviews-{{ section.id }}"
  data-pdp-reviews
  data-section-id="{{ section.id }}"
  data-product-title="{{ product.title | escape }}"
  data-imgbb-key="{{ section.settings.review_imgbb_api_key | escape }}"
>
  <header class="pdp-customer-reviews__head">
    <h2 class="pdp-customer-reviews__title" id="Reviews-{{ section.id }}">{{ heading }}</h2>
    <p class="pdp-customer-reviews__summary">
      <strong>{{ average }}</strong>
      <span>{{ total_label }}</span>
    </p>
  </header>

  {%- assign has_photos = false -%}
  {%- if has_meta_reviews -%}
    {%- for entry in shop.metaobjects[mo_type].values -%}
      {%- assign entry_product = entry.product.value -%}
      {%- if entry_product != blank and entry_product.id == product.id and entry.published.value != false and entry.photo.value != blank -%}
        {%- assign has_photos = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
  {%- else -%}
    {%- for block in review_blocks -%}
      {%- if block.settings.photo != blank or block.settings.avatar != blank -%}
        {%- assign has_photos = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}

  {%- if has_photos -%}
    <div class="pdp-customer-reviews__photos" aria-label="Customer photos">
      {%- if has_meta_reviews -%}
        {%- assign photo_i = 0 -%}
        {%- for entry in shop.metaobjects[mo_type].values -%}
          {%- assign entry_product = entry.product.value -%}
          {%- if entry_product != blank and entry_product.id == product.id and entry.published.value != false and entry.photo.value != blank -%}
            <button
              type="button"
              class="pdp-customer-reviews__photo"
              data-review-photo="{{ photo_i }}"
              aria-label="View customer photo {{ photo_i | plus: 1 }}"
            >
              <img
                src="{{ entry.photo.value | image_url: width: 200 }}"
                alt=""
                width="72"
                height="72"
                loading="lazy"
              >
            </button>
            {%- assign photo_i = photo_i | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        {%- for block in review_blocks -%}
          {%- liquid
            assign gallery_img = block.settings.photo
            if gallery_img == blank
              assign gallery_img = block.settings.avatar
            endif
          -%}
          {%- if gallery_img != blank -%}
            <button
              type="button"
              class="pdp-customer-reviews__photo"
              data-review-photo="{{ forloop.index0 }}"
              aria-label="View customer photo {{ forloop.index }}"
            >
              <img
                src="{{ gallery_img | image_url: width: 200 }}"
                alt=""
                width="72"
                height="72"
                loading="lazy"
              >
            </button>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if write_url != blank -%}
    <a href="{{ write_url }}" class="pdp-customer-reviews__write">Write a review</a>
  {%- else -%}
    <button type="button" class="pdp-customer-reviews__write" data-review-open>
      Write a review
    </button>
  {%- endif -%}

  <div data-review-success-slot></div>

  {%- unless write_url != blank -%}
    <div
      class="pdp-review-modal"
      data-review-modal
      hidden
      role="dialog"
      aria-modal="true"
      aria-labelledby="ReviewModalTitle-{{ section.id }}"
    >
      <div class="pdp-review-modal__backdrop" data-review-close tabindex="-1"></div>
      <div class="pdp-review-modal__panel">
        <div class="pdp-review-modal__head">
          <h3 id="ReviewModalTitle-{{ section.id }}">Write a review</h3>
          <button type="button" class="pdp-review-modal__close" data-review-close aria-label="Close">
            <span class="material-symbols-outlined" aria-hidden="true">close</span>
          </button>
        </div>
        <p class="pdp-review-modal__product">{{ product.title }}</p>

        {% form 'contact', id: review_form_id, class: 'pdp-review-form', data-review-form: '' %}
          {%- if form.posted_successfully? -%}
            <p class="pdp-customer-reviews__success" role="status" data-review-success>
              Thank you! Your review was submitted and will appear here after we approve it.
            </p>
            <button type="button" class="pdp-review-form__submit" data-review-close>Done</button>
          {%- else -%}
            <input type="hidden" name="contact[product]" value="{{ product.title | escape }}">
            <input type="hidden" name="contact[product_url]" value="{{ shop.url }}{{ product.url }}">
            <input type="hidden" name="contact[rating]" value="5" data-review-rating-input>
            <input type="hidden" name="contact[subject]" value="Product review: {{ product.title | escape }}">

            <div class="pdp-review-form__field">
              <span class="pdp-review-form__label">Your rating</span>
              <div class="pdp-review-form__stars" data-review-stars role="radiogroup" aria-label="Star rating">
                {%- for i in (1..5) -%}
                  <button
                    type="button"
                    class="pdp-review-form__star is-active"
                    data-review-star="{{ i }}"
                    aria-label="{{ i }} star{% if i > 1 %}s{% endif %}"
                  >★</button>
                {%- endfor -%}
              </div>
            </div>

            <label class="pdp-review-form__field">
              <span class="pdp-review-form__label">Your name</span>
              <input
                type="text"
                name="contact[name]"
                value="{% if customer %}{{ customer.name }}{% endif %}"
                required
                autocomplete="name"
                placeholder="Your name"
              >
            </label>

            <label class="pdp-review-form__field">
              <span class="pdp-review-form__label">Email</span>
              <input
                type="email"
                name="contact[email]"
                value="{% if customer %}{{ customer.email }}{% endif %}"
                required
                autocomplete="email"
                placeholder="you@email.com"
              >
            </label>

            <label class="pdp-review-form__field">
              <span class="pdp-review-form__label">Review title</span>
              <input type="text" name="contact[title]" required maxlength="120" placeholder="Sum up your experience">
            </label>

            <label class="pdp-review-form__field">
              <span class="pdp-review-form__label">Your review</span>
              <textarea
                name="contact[body]"
                rows="4"
                required
                maxlength="2000"
                placeholder="Tell others what you liked about this product"
                data-review-body
              ></textarea>
            </label>

            <div class="pdp-review-form__field">
              <span class="pdp-review-form__label">Add a photo <span class="pdp-review-form__optional">(optional)</span></span>
              <input type="hidden" name="contact[photo_url]" value="" data-review-photo-url>
              <label class="pdp-review-form__photo">
                <input
                  type="file"
                  accept="image/*"
                  capture="environment"
                  data-review-photo-input
                  class="visually-hidden"
                >
                <span class="pdp-review-form__photo-box" data-review-photo-box>
                  <span class="material-symbols-outlined" aria-hidden="true">add_a_photo</span>
                  <span data-review-photo-label>Tap to add picture</span>
                </span>
                <img class="pdp-review-form__photo-preview" data-review-photo-preview hidden alt="Selected photo preview">
              </label>
              <button type="button" class="pdp-review-form__photo-remove" data-review-photo-remove hidden>
                Remove photo
              </button>
            </div>

            {%- if form.errors -%}
              <p class="pdp-review-form__error" role="alert">
                {{ form.errors | default_errors }}
              </p>
            {%- endif -%}

            <p class="pdp-review-form__hint" data-review-photo-status hidden></p>

            <button type="submit" class="pdp-review-form__submit" data-review-submit>Submit review</button>
          {%- endif -%}
        {% endform %}
      </div>
    </div>
  {%- endunless -%}

  <div class="pdp-customer-reviews__bars" aria-label="Rating breakdown">
    {%- for star in (5..1) -%}
      {%- liquid
        case star
          when 5
            assign star_count = count_5
            assign star_pct = pct_5
          when 4
            assign star_count = count_4
            assign star_pct = pct_4
          when 3
            assign star_count = count_3
            assign star_pct = pct_3
          when 2
            assign star_count = count_2
            assign star_pct = pct_2
          else
            assign star_count = count_1
            assign star_pct = pct_1
        endcase
      -%}
      <div class="pdp-customer-reviews__bar-row">
        <span class="pdp-customer-reviews__bar-label">
          {{ star }}
          <span class="pdp-customer-reviews__star" aria-hidden="true">★</span>
        </span>
        <span class="pdp-customer-reviews__bar-track">
          <span class="pdp-customer-reviews__bar-fill" style="width: {{ star_pct }}%;"></span>
        </span>
        <span class="pdp-customer-reviews__bar-count">{{ star_count }}</span>
      </div>
    {%- endfor -%}
  </div>

  <div class="pdp-customer-reviews__toolbar">
    <button
      type="button"
      class="pdp-customer-reviews__filter-btn"
      data-review-filter-toggle
      aria-label="Filter reviews"
      aria-expanded="false"
    >
      <span class="material-symbols-outlined" aria-hidden="true">tune</span>
    </button>
    <div class="pdp-customer-reviews__filter-menu" data-review-filter-menu hidden>
      <button type="button" data-review-filter="all" class="is-active">All ratings</button>
      <button type="button" data-review-filter="5">5 stars</button>
      <button type="button" data-review-filter="4">4 stars</button>
      <button type="button" data-review-filter="3">3 stars</button>
      <button type="button" data-review-filter="2">2 stars</button>
      <button type="button" data-review-filter="1">1 star</button>
    </div>
    <label class="pdp-customer-reviews__sort">
      <span class="visually-hidden">Sort reviews</span>
      <select data-review-sort aria-label="Sort reviews">
        <option value="recent">Most recent</option>
        <option value="highest">Highest rating</option>
        <option value="lowest">Lowest rating</option>
      </select>
      <span class="material-symbols-outlined" aria-hidden="true">expand_more</span>
    </label>
  </div>

  <div class="pdp-customer-reviews__list" data-reviews-list>
    {%- if has_meta_reviews -%}
      {%- assign card_i = 0 -%}
      {%- for entry in shop.metaobjects[mo_type].values -%}
        {%- assign entry_product = entry.product.value -%}
        {%- if entry_product == blank or entry_product.id != product.id or entry.published.value == false -%}
          {%- continue -%}
        {%- endif -%}
        {%- liquid
          assign rating = entry.rating.value | default: 5 | plus: 0
          assign author = entry.author.value | default: 'Anonymous'
          assign initial = author | strip | slice: 0, 1 | upcase
          assign review_title = entry.title.value
          assign review_body = entry.body.value
          assign review_date = entry.date.value | default: entry.system.created_at | date: '%m/%d/%Y'
          assign sort_key = 1000 | minus: card_i
          assign is_verified = entry.verified.value
          if is_verified == blank
            assign is_verified = true
          endif
        -%}
        <article
          class="pdp-review-card"
          data-review-card
          data-rating="{{ rating }}"
          data-sort-order="{{ sort_key }}"
          data-index="{{ card_i }}"
        >
          <div class="pdp-review-card__stars" aria-label="{{ rating }} out of 5 stars">
            {%- for i in (1..5) -%}
              <span class="pdp-review-card__star{% if i <= rating %} is-filled{% endif %}" aria-hidden="true">★</span>
            {%- endfor -%}
          </div>
          <div class="pdp-review-card__meta">
            <div class="pdp-review-card__avatar" aria-hidden="true">
              <span>{{ initial }}</span>
            </div>
            <div class="pdp-review-card__author-wrap">
              <div class="pdp-review-card__author-row">
                <strong class="pdp-review-card__author">{{ author }}</strong>
                {%- if is_verified -%}
                  <span class="pdp-review-card__verified">
                    <span class="material-symbols-outlined" aria-hidden="true">verified</span>
                    Verified
                  </span>
                {%- endif -%}
              </div>
              <time class="pdp-review-card__date">{{ review_date }}</time>
            </div>
          </div>
          {%- if review_title != blank -%}
            <h3 class="pdp-review-card__title">{{ review_title }}</h3>
          {%- endif -%}
          {%- if review_body != blank -%}
            <p class="pdp-review-card__body">{{ review_body }}</p>
          {%- endif -%}
          {%- if entry.photo.value != blank -%}
            <div class="pdp-review-card__photo">
              <img
                src="{{ entry.photo.value | image_url: width: 400 }}"
                alt=""
                width="120"
                height="120"
                loading="lazy"
              >
            </div>
          {%- endif -%}
        </article>
        {%- assign card_i = card_i | plus: 1 -%}
      {%- endfor -%}
    {%- elsif review_blocks.size > 0 -%}
      {%- for block in review_blocks -%}
        {%- liquid
          assign rating = block.settings.rating | default: 5 | plus: 0
          assign author = block.settings.author | default: 'Anonymous'
          assign initial = author | strip | slice: 0, 1 | upcase
          assign review_title = block.settings.title
          assign review_body = block.settings.quote
          assign review_date = block.settings.date | default: '07/21/2026'
          assign sort_key = review_blocks.size | minus: forloop.index0
        -%}
        <article
          class="pdp-review-card"
          data-review-card
          data-rating="{{ rating }}"
          data-sort-order="{{ sort_key }}"
          data-index="{{ forloop.index0 }}"
          {{ block.shopify_attributes }}
        >
          <div class="pdp-review-card__stars" aria-label="{{ rating }} out of 5 stars">
            {%- for i in (1..5) -%}
              <span class="pdp-review-card__star{% if i <= rating %} is-filled{% endif %}" aria-hidden="true">★</span>
            {%- endfor -%}
          </div>
          <div class="pdp-review-card__meta">
            <div class="pdp-review-card__avatar" aria-hidden="true">
              {%- if block.settings.avatar != blank -%}
                <img src="{{ block.settings.avatar | image_url: width: 80 }}" alt="" width="40" height="40" loading="lazy">
              {%- else -%}
                <span>{{ initial }}</span>
              {%- endif -%}
            </div>
            <div class="pdp-review-card__author-wrap">
              <div class="pdp-review-card__author-row">
                <strong class="pdp-review-card__author">{{ author }}</strong>
                {%- unless block.settings.verified == false -%}
                  <span class="pdp-review-card__verified">
                    <span class="material-symbols-outlined" aria-hidden="true">verified</span>
                    Verified
                  </span>
                {%- endunless -%}
              </div>
              <time class="pdp-review-card__date" datetime="{{ review_date }}">{{ review_date }}</time>
            </div>
          </div>
          {%- if review_title != blank -%}
            <h3 class="pdp-review-card__title">{{ review_title }}</h3>
          {%- endif -%}
          {%- if review_body != blank -%}
            <p class="pdp-review-card__body">{{ review_body }}</p>
          {%- endif -%}
          {%- if block.settings.photo != blank -%}
            <div class="pdp-review-card__photo">
              <img
                src="{{ block.settings.photo | image_url: width: 400 }}"
                alt=""
                width="120"
                height="120"
                loading="lazy"
              >
            </div>
          {%- endif -%}
        </article>
      {%- endfor -%}
    {%- else -%}
      <p class="pdp-customer-reviews__empty">No published reviews yet. Approve the first one in Content → Metaobjects.</p>
    {%- endif -%}
  </div>
</section>
