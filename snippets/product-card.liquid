{%- comment -%} Product card — matches storefront .bs-card {%- endcomment -%}
{%- liquid
  assign card_product = product
  assign variant = card_product.selected_or_first_available_variant
-%}
<article class="bs-card">
  <a href="{{ card_product.url }}" class="bs-card__media">
    {%- if badge != blank -%}
      <span class="bs-card__badge">{{ badge }}</span>
    {%- elsif card_product.tags contains 'bestseller' or card_product.tags contains 'Best Seller' -%}
      <span class="bs-card__badge">Best Seller</span>
    {%- endif -%}
    {%- if card_product.featured_media -%}
      <img
        src="{{ card_product.featured_media | image_url: width: 600 }}"
        alt="{{ card_product.featured_media.alt | escape | default: card_product.title | escape }}"
        width="400"
        height="480"
        loading="lazy"
      >
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag }}
    {%- endif -%}
  </a>
  <div class="bs-card__body">
    <h3 class="bs-card__title">
      <a href="{{ card_product.url }}">{{ card_product.title }}</a>
    </h3>
    {%- if show_rating -%}
      <div class="bs-card__rating"><span class="bs-card__stars" aria-hidden="true">★★★★★</span></div>
    {%- endif -%}
    {%- if variant.title != 'Default Title' -%}
      <p class="bs-card__size">{{ variant.title }}</p>
    {%- endif -%}
    {% render 'price', product: card_product %}
    {%- if variant.available -%}
      <button
        type="button"
        class="bs-card__btn"
        data-add-variant="{{ variant.id }}"
      >
        <span class="material-symbols-outlined" aria-hidden="true">shopping_cart</span>
        {{ 'products.product.add_to_cart' | t }}
      </button>
    {%- else -%}
      <button type="button" class="bs-card__btn" disabled>{{ 'products.product.sold_out' | t }}</button>
    {%- endif -%}
  </div>
</article>
